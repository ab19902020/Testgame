          const initGame = (mode, mapKey, themeKey, isNetworked = false, customBoard = null) => {
            try {
                Sfx.init(); Sfx.playUI(); Sfx.updateFuseSound(0); 
                keys.current = {}; actionPrimaryBtn.current = false; actionSecondaryBtn.current = false; touchDpad.current = {x:0, y:0};
                remoteInputsRef.current = {};

                const { cols, rows, players: maxPlayers } = customBoard ? MAP_SIZES['CUSTOM'] : MAP_SIZES[mapKey];
                const theme = MAP_THEMES[themeKey];
                GameJuice.particles = []; GameJuice.shockwaves = []; GameJuice.shakeIntensity = 0;
                
                let board = customBoard ? [...customBoard] : new Array(rows * cols).fill(0);
                if (!customBoard) {
                    for (let r = 0; r < rows; r++) {
                      for (let c = 0; c < cols; c++) {
                        if (r === 0 || r === rows - 1 || c === 0 || c === cols - 1) board[r * cols + c] = 1;
                        else if (r % 2 === 0 && c % 2 === 0) board[r * cols + c] = 1;
                      }
                    }
                }
                
                const getStartPos = (c, r) => {
                    const midC = (Math.floor(c/2) % 2 === 0) ? Math.floor(c/2)+1 : Math.floor(c/2);
                    return [
                      { c: 1, r: 1 }, { c: c - 2, r: r - 2 }, { c: 1, r: r - 2 }, { c: c - 2, r: 1 },
                      { c: midC, r: 1 }, { c: midC, r: r - 2 }
                    ];
                };
                const startPos = getStartPos(cols, rows);
                
                if (!customBoard) {
                    const safeZones = []; startPos.forEach(pos => safeZones.push([pos.c, pos.r], [pos.c+1, pos.r], [pos.c-1, pos.r], [pos.c, pos.r+1], [pos.c, pos.r-1]));
                    for (let r = 1; r < rows - 1; r++) {
                      for (let c = 1; c < cols - 1; c++) {
                        if (board[r * cols + c] === 1) continue;
                        if (!safeZones.some(z => z[0] === c && z[1] === r) && Math.random() < 0.85) board[r * cols + c] = 2; 
                      }
                    }
                }

                const crateIndices = []; for(let i=0; i<board.length; i++) if (board[i] === 2) crateIndices.push(i);
                crateIndices.sort(() => Math.random() - 0.5);

                const hiddenItems = {}; const pool = []; const add = (pu, qty) => { for(let i=0; i<qty; i++) pool.push(pu); }
                
                if (mode.id === 'mayhem') {
                    add(POWERUPS.MEGA, 5); add(POWERUPS.DIRTY, 5); add(POWERUPS.GHOST, 5); add(POWERUPS.FREEZE, 5); add(POWERUPS.GLOVE, 5); add(POWERUPS.DINO, 6); add(POWERUPS.HORSE, 6); add(POWERUPS.MECH, 6); add(POWERUPS.DOLPHIN, 6);
                } else if (mode.id === 'crazy') {
                    add(POWERUPS.BOMB, 10); add(POWERUPS.FIRE, 10); add(POWERUPS.SPEED, 10); add(POWERUPS.DINO, 5); add(POWERUPS.MECH, 5); add(POWERUPS.HORSE, 5); add(POWERUPS.DOLPHIN, 5); add(POWERUPS.MEGA, 3);
                } else if (mode.id === 'sniper') {
                    add(POWERUPS.BOMB, 2); add(POWERUPS.SPEED, 10); add(POWERUPS.KICK, 5); add(POWERUPS.SHIELD, 3); add(POWERUPS.HORSE, 2);
                } else {
                    add(POWERUPS.BOMB, 16); add(POWERUPS.FIRE, 14); add(POWERUPS.SPEED, 10);
                    if (mode.id !== 'easy') { add(POWERUPS.KICK, 2); add(POWERUPS.PUNCH, 1); add(POWERUPS.GLOVE, 2); }
                    add(POWERUPS.MEGA, 2); add(POWERUPS.DIRTY, 2); add(POWERUPS.SHIELD, 2); add(POWERUPS.MAX_FIRE, 1);
                    add(POWERUPS.GHOST, 1); add(POWERUPS.SKULL, 3); add(POWERUPS.HEART, 1); add(POWERUPS.FREEZE, 1); add(POWERUPS.MYSTERY, 2);
                    add(POWERUPS.DINO, 3); add(POWERUPS.MECH, 2); add(POWERUPS.HORSE, 2); add(POWERUPS.DOLPHIN, 2);
                }
                
                pool.sort(() => Math.random() - 0.5); pool.forEach(item => { if (crateIndices.length > 0) hiddenItems[crateIndices.pop()] = item; });

                let spiral = []; let top = 1, bottom = rows-2, left = 1, right = cols-2;
                while (top <= bottom && left <= right) {
                    for (let c = left; c <= right; c++) spiral.push({c, r: top}); top++;
                    for (let r = top; r <= bottom; r++) spiral.push({c: right, r}); right--;
                    if (top <= bottom) { for (let c = right; c >= left; c--) spiral.push({c, r: bottom}); bottom--; }
                    if (left <= right) { for (let r = bottom; r >= top; r--) spiral.push({c: left, r}); left++; }
                }

                const isSniper = mode.id === 'sniper'; const isTeam = mode.isTeam;

