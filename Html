              if (isCritical && Math.floor(timeMs / 25) % 2 === 0) { shellColor = '#FFF'; highColor = '#FFF'; }

              const grad = ctx.createRadialGradient(bx-5, by-5, 0, bx, by, 20);
              grad.addColorStop(0, highColor); grad.addColorStop(1, shellColor);
              ctx.fillStyle = grad; ctx.beginPath(); ctx.arc(bx, by, 20 * scale, 0, Math.PI*2); ctx.fill(); 
              ctx.lineWidth=2; ctx.strokeStyle= '#000'; ctx.stroke();
              
              if (b.isDirty) { ctx.fillStyle = '#10B981'; ctx.font='bold 20px Arial'; ctx.textAlign='center'; ctx.fillText('☣', bx, by+6); }
              else if (b.isMega) { ctx.fillStyle = '#D946EF'; ctx.font='bold 20px Arial'; ctx.textAlign='center'; ctx.fillText('☢', bx, by+6); }
              else { 
                 ctx.fillStyle = '#FFF'; ctx.beginPath(); ctx.arc(bx-6, by-6, 6 * scale, 0, Math.PI*2); ctx.fill(); 
                 ctx.strokeStyle = '#F59E0B'; ctx.lineWidth = 4; ctx.beginPath(); ctx.moveTo(bx, by-18); ctx.quadraticCurveTo(bx+8, by-28, bx+14, by-22); ctx.stroke();
                 const isSparking = Math.floor(timeMs / 50) % 2 === 0;
                 ctx.fillStyle = isSparking ? '#FFF' : '#EF4444'; ctx.beginPath(); ctx.arc(bx+14, by-22, 5+Math.random()*4, 0, Math.PI*2); ctx.fill(); 
              }
          }
        };

