                let boss = null;
                if (mode.id === 'boss') boss = { active: true, x: (cols/2)*TILE_SIZE, y: (rows/2)*TILE_SIZE, vx: 0, vy: 0, hp: 50, maxHp: 50, state: 'chase', stateTimer: 0, speed: 2.0, targetId: null };

                const cRes = Math.min(RES, Math.floor(MAX_CANVAS_DIMENSION / Math.max(cols * TILE_SIZE, rows * TILE_SIZE)));

                state.current = {
                  mode, cols, rows, width: cols * TILE_SIZE, height: rows * TILE_SIZE, theme, currentRes: cRes,
                  board, players, bombs: [], explosions: [], powerups: [], hiddenItems, dropCounts: {},
                  timer: mode.timer, winner: null, winTimer: 0, frame: 0, freezeTimer: 0,
