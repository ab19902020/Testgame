                };
                
                lastTimeRef.current = 0; hitStopRef.current = 0; setView('playing');
                if (isNetworked && networkState === 'host' && roomId) setDoc(doc(db, 'artifacts', appId, 'public', 'data', 'rooms', roomId), { status: 'playing' }, {merge:true});
            } catch(e) { console.error("Init Error:", e); }
          };

          const processDeath = (p) => {
              const s = state.current;
              if (p.mount) {
                   p.mount = null; p.iFrames = 2000; p.hasPunch = false; p.hasKick = false; p.isDiving = 0; p.z = 0;
                   GameJuice.emitText(p.x, p.y, "MOUNT DESTROYED!", "#F00"); Sfx.playShieldBreak(); return; 
              }
              p.lives--; Sfx.playDeath();
              if (p.carriedBombId) { const b = s.bombs.find(bomb => bomb.id === p.carriedBombId); if (b) { b.carriedBy = null; b.z = 0; } p.carriedBombId = null; }

              const scatter = [];
              if (p.maxBombs > 1) scatter.push(POWERUPS.BOMB);
              if (p.range > 1 && s.mode.id !== 'sniper') scatter.push(POWERUPS.FIRE);
              if (p.speed > 5.0) scatter.push(POWERUPS.SPEED);
              if (p.hasMega) scatter.push(POWERUPS.MEGA);
              if (p.hasDirty) scatter.push(POWERUPS.DIRTY);
              
              scatter.slice(0, 10).forEach(type => {
                  const angle = Math.random() * Math.PI * 2; const spd = 3 + Math.random() * 5;
                  s.powerups.push({ id: `pu_${Math.random()}`, c: Math.floor(p.x/TILE_SIZE), r: Math.floor(p.y/TILE_SIZE), type, px: p.x, py: p.y, z: 20 + Math.random()*20, vx: Math.cos(angle)*spd, vy: Math.sin(angle)*spd, vz: 8 + Math.random()*6, isFlying: true });
              });

              if (p.lives <= 0) {
                  p.alive = false; GameJuice.emitSparks(p.x, p.y, '#F00'); GameJuice.emitSmoke(p.x, p.y); GameJuice.emitText(p.x, p.y, "ELIMINATED!", "#F00");
              } else {
                  p.x = Math.max(TILE_SIZE*1.5, Math.min(s.width-TILE_SIZE*1.5, p.x)); p.y = Math.max(TILE_SIZE*1.5, Math.min(s.height-TILE_SIZE*1.5, p.y));
                  p.iFrames = 2000; p.z = 0; p.isDiving = 0;
                  p.maxBombs = Math.max(1, p.maxBombs - 1); p.range = s.mode.id === 'sniper' ? 15 : Math.max(1, p.range - 1);
                  p.speed = Math.max(p.isBot ? (4.2 * s.mode.botSpeed) : 4.8, p.speed - 0.6);
                  p.hasMega = false; p.hasDirty = false; p.isGhost = false; p.hasShield = false;
                  GameJuice.emitText(p.x, p.y, "RESPAWNED!", "#FFF");
              }
          };

          const triggerExplosion = (bomb) => {
            if (bomb.exploded) return;
            bomb.exploded = true; // Safely mark as exploded to prevent chain-reaction memory crash!
            
            const s = state.current; Sfx.playExplosion(bomb.isDirty, bomb.isMega, bomb.range);
            GameJuice.triggerShake(bomb.isDirty ? 35 : (bomb.isMega ? 20 : 8));
            if (bomb.carriedBy) { const carrier = s.players.find(p => p.id === bomb.carriedBy); if (carrier) carrier.carriedBombId = null; }
            const isWalkableOrSoft = (c, r) => c > 0 && c < s.cols-1 && r > 0 && r < s.rows-1 && s.board[r * s.cols + c] !== 1;

            const expandExplosion = (c, r, timer, isDirty, isMega) => {
                if (!isWalkableOrSoft(c, r)) return;
                if (s.boss && s.boss.active) {
                    const bc = Math.floor(s.boss.x/TILE_SIZE); const br = Math.floor(s.boss.y/TILE_SIZE);
                    if (c >= bc-1 && c <= bc+1 && r >= br-1 && r <= br+1) { s.boss.hp -= (isMega ? 5 : (isDirty ? 3 : 1)); GameJuice.emitSparks(s.boss.x, s.boss.y, '#FFF'); if (s.boss.hp <= 0) s.boss.active = false; }
                }
                s.explosions.push({ c, r, timer, maxTimer: timer, isDirty, isMega, owner: bomb.owner });
                const puIndex = s.powerups.findIndex(p => p.c === c && p.r === r && !p.isFlying);
                if (puIndex !== -1) { s.powerups.splice(puIndex, 1); GameJuice.emitSparks(c*TILE_SIZE+TILE_SIZE/2, r*TILE_SIZE+TILE_SIZE/2, '#FFF'); }
                if (s.board[r * s.cols + c] === 2) { 
                    s.board[r * s.cols + c] = 0; s.bgNeedsRedraw = true;
                    GameJuice.emitDebris(c, r, s.theme.id); GameJuice.emitSmoke(c*TILE_SIZE+TILE_SIZE/2, r*TILE_SIZE+TILE_SIZE/2, '#8B4513');
                    const dropType = s.hiddenItems[r * s.cols + c];
                    if (dropType) { s.powerups.push({ id:`pu_${Math.random()}`, c, r, type: dropType, px: c*TILE_SIZE+TILE_SIZE/2, py: r*TILE_SIZE+TILE_SIZE/2, z:0, isFlying:false }); delete s.hiddenItems[r * s.cols + c]; }
                }
                const hitBomb = s.bombs.find(b => b.c === c && b.r === r && !b.isFlying && !b.carriedBy);
                if (hitBomb && !hitBomb.exploded) triggerExplosion(hitBomb); 
            };

            GameJuice.emitShockwave(bomb.px, bomb.py, bomb.isDirty ? '#10B981' : (bomb.isMega ? '#D946EF' : '#F59E0B'));

            if (bomb.isDirty) {
               const rRad = Math.min(6, 3 + Math.floor(bomb.range / 2)); 
               for(let r = -rRad; r <= rRad; r++) for(let c = -rRad; c <= rRad; c++) expandExplosion(bomb.c+c, bomb.r+r, 1200, true, false);
            } else if (bomb.isMega) {
               const rRad = Math.min(4, bomb.range); 
               for(let r = -rRad; r <= rRad; r++) for(let c = -rRad; c <= rRad; c++) expandExplosion(bomb.c+c, bomb.r+r, 800, false, true);
            } else {
               expandExplosion(bomb.c, bomb.r, 500, false, false); const dirs = [{x:1, y:0}, {x:-1, y:0}, {x:0, y:1}, {x:0, y:-1}];
               dirs.forEach(dir => { for (let i = 1; i <= bomb.range; i++) { const nc = bomb.c + dir.x * i; const nr = bomb.r + dir.y * i; if (s.board[nr * s.cols + nc] === 1) break; expandExplosion(nc, nr, 500, false, false); if (s.board[nr * s.cols + nc] === 2) break; } });
            }
          };

          const handleBombDrop = (p) => {
            const s = state.current;
            if (!p.alive || p.iFrames > 0 || p.carriedBombId || p.z > 0 || p.isDiving > 0) return;
            if (p.skullTimer > 0 && Math.random() < 0.3) return; 
            const activeBombsCount = s.bombs.filter(b => b.owner === p.id && !b.exploded).length;
            if (activeBombsCount >= p.maxBombs) return;

            const myC = Math.floor(p.x / TILE_SIZE); const myR = Math.floor(p.y / TILE_SIZE);
            if (s.bombs.some(b => b.c === myC && b.r === myR && !b.isFlying && !b.carriedBy)) return; 

            const isFirstBomb = activeBombsCount === 0;
            const isDirty = p.hasDirty && isFirstBomb; const isMega = p.hasMega && isFirstBomb && !isDirty;

            s.bombs.push({
              id: `b_${Math.random()}`, c: myC, r: myR, px: myC*TILE_SIZE + TILE_SIZE/2, py: myR*TILE_SIZE + TILE_SIZE/2,
              range: p.range, owner: p.id, timer: 3000, dx: 0, dy: 0, isDirty: isDirty, isMega: isMega,
              isFlying: false, carriedBy: null, z: 0, ignoredBy: [p.id], exploded: false
            });
            Sfx.playDrop();
          };

          const handleSecondaryAction = (p) => {
              const s = state.current;
              if (!p.alive || p.iFrames > 0 || p.isDiving > 0 || p.z > 0) return;

              if (p.mount === 16) { 
                  Sfx.playRoar(); let dx = 0, dy = 0;
                  if (p.dir === 'up') dy = -1; else if (p.dir === 'down') dy = 1; else if (p.dir === 'left') dx = -1; else if (p.dir === 'right') dx = 1;
                  const myC = Math.floor(p.x / TILE_SIZE); const myR = Math.floor(p.y / TILE_SIZE);
                  for(let i=1; i<=3; i++) {
                      const nc = myC + dx*i; const nr = myR + dy*i;
                      if (nc<=0 || nc>=s.cols-1 || nr<=0 || nr>=s.rows-1 || s.board[nr*s.cols+nc] === 1) break;
                      s.explosions.push({ c: nc, r: nr, timer: 400, maxTimer: 400, isDirty: false, isMega: false, owner: p.id });
                      if (s.board[nr*s.cols+nc] === 2) {
                          s.board[nr*s.cols+nc] = 0; s.bgNeedsRedraw = true; GameJuice.emitDebris(nc, nr, s.theme.id);
                          const dropType = s.hiddenItems[nr*s.cols+nc];
                          if(dropType) { s.powerups.push({ id:`pu_${Math.random()}`, c:nc, r:nr, type: dropType, px: nc*TILE_SIZE+TILE_SIZE/2, py: nr*TILE_SIZE+TILE_SIZE/2, z:0, isFlying:false }); delete s.hiddenItems[nr*s.cols+nc]; }
                          break;
                      }
                  }
                  return;
              } else if (p.mount === 18) { 
                  Sfx.playNeigh(); p.vz = 25; p.isFlying = true; p.flyDistance = 0; p.flyTargetDist = 2;
                  let dx = 0, dy = 0;
                  if (p.dir === 'up') dy = -1; else if (p.dir === 'down') dy = 1; else if (p.dir === 'left') dx = -1; else if (p.dir === 'right') dx = 1;
                  p.flyDx = dx; p.flyDy = dy; return;
              } else if (p.mount === 19) { 
                  Sfx.playSplash(); p.isDiving = 2500; GameJuice.emitText(p.x, p.y-20, "DIVE!", "#0284C7"); return;
              }

              if (p.carriedBombId) {
                  const bomb = s.bombs.find(b => b.id === p.carriedBombId);
                  if (bomb) {
                      p.carriedBombId = null; bomb.carriedBy = null; bomb.isFlying = true;
                      let dx = 0, dy = 0;
                      if (p.dir === 'up') dy = -1; else if (p.dir === 'down') dy = 1; else if (p.dir === 'left') dx = -1; else if (p.dir === 'right') dx = 1;
                      bomb.dx = dx; bomb.dy = dy; bomb.px = p.x; bomb.py = p.y; bomb.c = Math.floor(p.x/TILE_SIZE); bomb.r = Math.floor(p.y/TILE_SIZE);
                      bomb.flyDistance = 0; bomb.flyTargetDist = 3; Sfx.playDrop(); 
                  }
                  return;
              }

              const myC = Math.floor(p.x / TILE_SIZE); const myR = Math.floor(p.y / TILE_SIZE);
              const bombUnderMe = s.bombs.find(b => b.c === myC && b.r === myR && b.dx === 0 && b.dy === 0 && !b.isFlying && !b.carriedBy);

              if (p.hasGlove && bombUnderMe) { bombUnderMe.carriedBy = p.id; p.carriedBombId = bombUnderMe.id; return; }

              if (p.hasPunch || p.mount === 17) {
                 let tc = myC, tr = myR; let dx = 0, dy = 0;
                 if (p.dir === 'up') { tr--; dy = -1; } else if (p.dir === 'down') { tr++; dy = 1; } else if (p.dir === 'left') { tc--; dx = -1; } else if (p.dir === 'right') { tc++; dx = 1; }
                 const bomb = s.bombs.find(b => b.c === tc && b.r === tr && b.dx === 0 && b.dy === 0 && !b.isFlying && !b.carriedBy);
                 if (bomb) { bomb.dx = dx; bomb.dy = dy; bomb.isFlying = true; bomb.flyDistance = 0; bomb.flyTargetDist = 3; Sfx.playDrop(); }
              }
          }

          const updateEntities = (dt) => {
            const s = state.current;
            
            if (s.frame % 60 === 0 && s.timer > 0) {
                s.timer--;
                const triggerTime = s.mode.id === 'blitz' ? 30 : 60; 
                if (s.mode.suddenDeath && s.timer <= triggerTime && s.timer % 2 === 0 && s.hurryUpIndex < s.hurryUpSpiral.length) {
                    const tile = s.hurryUpSpiral[s.hurryUpIndex]; s.fallingBlocks.push({ c: tile.c, r: tile.r, y: -400, timer: 30 }); s.hurryUpIndex++;
                }
            }

            if (s.freezeTimer > 0) s.freezeTimer -= dt;

            s.players.forEach(p => { 
                if (p.iFrames > 0) p.iFrames -= dt; 
                if (p.isDiving > 0) p.isDiving -= dt;
                if (p.z > 0 || p.isFlying) {
                    const speed = 25 * (dt/16);
                    p.x += p.flyDx * speed; p.y += p.flyDy * speed; p.flyDistance += speed;
                    const distRatio = p.flyDistance / (p.flyTargetDist * TILE_SIZE);
                    p.z = Math.sin(Math.PI * Math.min(1, distRatio)) * 50; 

                    if (p.flyDistance >= p.flyTargetDist * TILE_SIZE) {
                        const landC = Math.floor(p.x / TILE_SIZE); const landR = Math.floor(p.y / TILE_SIZE);
                        if (landC <= 0 || landC >= s.cols-1 || landR <= 0 || landR >= s.rows-1 || s.board[landR * s.cols + landC] !== 0) {
                            p.flyDx *= -1; p.flyDy *= -1; p.flyTargetDist = 1; p.flyDistance = 0;
                        } else {
                            p.isFlying = false; p.z = 0; p.x = landC * TILE_SIZE + TILE_SIZE/2; p.y = landR * TILE_SIZE + TILE_SIZE/2; Sfx.playDrop();
                        }
                    }
                }
            });

            if (s.boss && s.boss.active) {
                let b = s.boss; b.stateTimer -= dt;
                const bc = Math.floor(b.x/TILE_SIZE); const br = Math.floor(b.y/TILE_SIZE);
                [[0,0],[1,0],[0,1],[1,1]].forEach(d => {
                     const idx = (br+d.r)*s.cols + (bc+d.c);
                     if (s.board[idx] === 2) { s.board[idx] = 0; s.bgNeedsRedraw = true; GameJuice.emitDebris(bc+d.c, br+d.r, s.theme.id); Sfx.playDrop(); }
                });

                if (b.state === 'chase') {
                    if (!b.targetId || Math.random() < 0.05) { const alive = s.players.filter(p=>p.alive); if (alive.length > 0) b.targetId = alive[Math.floor(Math.random()*alive.length)].id; }
                    const targetP = s.players.find(p=>p.id===b.targetId && p.alive);
                    if (targetP) {
                        const dx = targetP.x - b.x; const dy = targetP.y - b.y; const mag = Math.hypot(dx, dy);
                        if (mag > 0) {
                            const nx = b.x + (dx/mag)*b.speed*(dt/16); const ny = b.y + (dy/mag)*b.speed*(dt/16);
                            const nC = Math.floor(nx/TILE_SIZE); const nR = Math.floor(ny/TILE_SIZE);
                            if (s.board[nR*s.cols+nC] !== 1 && s.board[(nR+1)*s.cols+(nC+1)] !== 1) { b.x = nx; b.y = ny; }
                        }
                    }
                    if (b.stateTimer <= 0) { b.state = 'charge_laser'; b.stateTimer = 2000; Sfx.playBossWarn(); GameJuice.triggerShake(5); }
                } else if (b.state === 'charge_laser') {
                    if (b.stateTimer <= 0) {
                        b.state = 'laser'; b.stateTimer = 500; Sfx.playExplosion(false, true, 15); GameJuice.triggerShake(20);
                        for(let c=1; c<s.cols-1; c++) { if (s.board[br*s.cols+c]!==1) s.explosions.push({c, r:br, timer:500, maxTimer:500, isDirty:false, isMega:true}); }
                        for(let r=1; r<s.rows-1; r++) { if (s.board[r*s.cols+bc]!==1) s.explosions.push({c:bc, r, timer:500, maxTimer:500, isDirty:false, isMega:true}); }
                    }
                } else if (b.state === 'laser') {
                    if (b.stateTimer <= 0) { b.state = 'chase'; b.stateTimer = 5000 + Math.random()*3000; }
                }
                s.players.forEach(p => { if (p.alive && p.iFrames <= 0 && p.isDiving <= 0 && p.z <= 0 && Math.abs(p.x - b.x) < 40 && Math.abs(p.y - b.y) < 40) processDeath(p); });
            }

            s.powerups.forEach(pu => {
                if (pu.isFlying) {
                    pu.px += pu.vx * (dt/16); pu.py += pu.vy * (dt/16); pu.z += pu.vz * (dt/16); pu.vz -= 0.8 * (dt/16); 
                    if (pu.z <= 0) {
                        pu.z = 0; pu.vz *= -0.5; pu.vx *= 0.6; pu.vy *= 0.6;
                        if (Math.abs(pu.vz) < 1 && Math.abs(pu.vx) < 1 && Math.abs(pu.vy) < 1) {
                            pu.isFlying = false;
                            pu.c = Math.max(1, Math.min(s.cols-2, Math.round(pu.px / TILE_SIZE)));
                            pu.r = Math.max(1, Math.min(s.rows-2, Math.round(pu.py / TILE_SIZE)));
                            pu.px = pu.c * TILE_SIZE + TILE_SIZE/2; pu.py = pu.r * TILE_SIZE + TILE_SIZE/2;
                        }
                    }
                }
            });

            for (let i=s.fallingBlocks.length-1; i>=0; i--) {
                let b = s.fallingBlocks[i]; b.timer -= dt/16; b.y += 18;
                if (b.y >= 0) {
                    s.board[b.r * s.cols + b.c] = 1; s.bgNeedsRedraw = true; 
                    GameJuice.emitDebris(b.c, b.r, s.theme.id); GameJuice.emitSmoke(b.c*TILE_SIZE+TILE_SIZE/2, b.r*TILE_SIZE+TILE_SIZE/2);
                    Sfx.playDrop();
                    s.players.forEach(p => { if (p.alive && Math.floor(p.x/TILE_SIZE)===b.c && Math.floor(p.y/TILE_SIZE)===b.r) processDeath(p); });
                    s.bombs.filter(bm=>bm.c===b.c && bm.r===b.r).forEach(bm => triggerExplosion(bm));
                    GameJuice.triggerShake(15); s.fallingBlocks.splice(i,1);
                }
            }

            for (let i = s.bombs.length - 1; i >= 0; i--) {
              const b = s.bombs[i]; 

              if (b.ignoredBy && b.ignoredBy.length > 0) {
                  b.ignoredBy = b.ignoredBy.filter(pid => {
                      const p = s.players.find(pl => pl.id === pid);
                      if (!p || !p.alive) return false;
                      const pLeft = p.x - 12; const pRight = p.x + 12; const pTop = p.y - 12; const pBottom = p.y + 12;
                      const bLeft = b.c*TILE_SIZE; const bRight = bLeft+TILE_SIZE; const bTop = b.r*TILE_SIZE; const bBottom = bTop+TILE_SIZE;
                      return !(pLeft >= bRight || pRight <= bLeft || pTop >= bBottom || pBottom <= bTop);
                  });
              }

              if (b.carriedBy) {
                  const carrier = s.players.find(p => p.id === b.carriedBy);
                  if (carrier && carrier.alive) {
                      b.px = carrier.x; b.py = carrier.y; b.z = 36; b.c = Math.floor(b.px / TILE_SIZE); b.r = Math.floor(b.py / TILE_SIZE);
                      continue; 
                  } else { b.carriedBy = null; b.z = 0; }
              }

              b.timer -= dt;

              if (b.dx !== 0 || b.dy !== 0) {
                  const speed = 18 * (dt/16);
                  if (b.isFlying) {
                      b.px += b.dx * speed; b.py += b.dy * speed; b.flyDistance += speed;
                      const distRatio = b.flyDistance / (b.flyTargetDist * TILE_SIZE);
                      b.z = Math.sin(Math.PI * Math.min(1, distRatio)) * 40; 
                      if (b.flyDistance >= b.flyTargetDist * TILE_SIZE) {
                          const landC = Math.round(b.px / TILE_SIZE); const landR = Math.round(b.py / TILE_SIZE);
                          if (landC <= 0 || landC >= s.cols-1 || landR <= 0 || landR >= s.rows-1) { b.dx *= -1; b.dy *= -1; b.flyTargetDist = 1; b.flyDistance = 0; } 
                          else {
                              const isWall = s.board[landR * s.cols + landC] !== 0;
                              const hasBomb = s.bombs.some(ob => ob.id !== b.id && ob.c === landC && ob.r === landR && !ob.carriedBy);
                              if (isWall || hasBomb) { b.flyTargetDist = 1; b.flyDistance = 0; b.px = landC * TILE_SIZE + TILE_SIZE/2; b.py = landR * TILE_SIZE + TILE_SIZE/2; } 
                              else { b.isFlying = false; b.dx = 0; b.dy = 0; b.z = 0; b.c = landC; b.r = landR; b.px = landC * TILE_SIZE + TILE_SIZE/2; b.py = landR * TILE_SIZE + TILE_SIZE/2; }
                          }
                      }
                  } else {
                      let nx = b.px + b.dx * speed; let ny = b.py + b.dy * speed; b.z = 0;
                      const margin = 12; const left = nx - margin, right = nx + margin, top = ny - margin, bottom = ny + margin; let blocked = false;
                      for (let r = Math.floor(top/TILE_SIZE); r <= Math.floor(bottom/TILE_SIZE); r++) {
                         for (let c = Math.floor(left/TILE_SIZE); c <= Math.floor(right/TILE_SIZE); c++) {
                             if (s.board[r * s.cols + c] !== 0) blocked = true;
                             if (s.bombs.some(ob => ob.id !== b.id && ob.c === c && ob.r === r && !ob.isFlying && !ob.carriedBy)) blocked = true;
                             if (s.players.some(p => p.alive && p.z <= 0 && Math.abs(p.x - nx)<30 && Math.abs(p.y - ny)<30 && Math.abs(p.x - b.px) >= 30)) blocked = true;
                         }
                      }
                      if (blocked) { b.dx = 0; b.dy = 0; b.px = b.c * TILE_SIZE + TILE_SIZE/2; b.py = b.r * TILE_SIZE + TILE_SIZE/2; } 
                      else { b.px = nx; b.py = ny; b.c = Math.floor(b.px / TILE_SIZE); b.r = Math.floor(b.py / TILE_SIZE); }
                  }
              }

              // Fire explosions if timer 0
              if (b.timer <= 0 && !b.exploded) triggerExplosion(b);
            }
            
            // Clean up exploded bombs SAFELY to prevent memory loops/crashes
            s.bombs = s.bombs.filter(b => !b.exploded);

            const activeBombsCount = s.bombs.filter(b => b.timer > 0 && !b.isFlying).length;
            if (activeBombsCount !== s.lastBombCount) { Sfx.updateFuseSound(activeBombsCount); s.lastBombCount = activeBombsCount; }

            for (let i = s.explosions.length - 1; i >= 0; i--) {
              const e = s.explosions[i]; e.timer -= dt;
              if (e.timer <= 0) {
                  s.explosions.splice(i, 1);
              } else {
                  const ex = e.c * TILE_SIZE + TILE_SIZE/2; const ey = e.r * TILE_SIZE + TILE_SIZE/2;
                  s.players.forEach(p => {
                      if (!p.alive || p.iFrames > 0 || p.isDiving > 0 || p.z > 0) return; 
                      if (Math.abs(p.x - ex) < TILE_SIZE * 0.65 && Math.abs(p.y - ey) < TILE_SIZE * 0.65) {
                          if (p.hasShield) { p.hasShield = false; p.iFrames = 1000; Sfx.playShieldBreak(); GameJuice.emitText(p.x, p.y, "SHIELD BROKEN!", "#00FFFF"); } 
                          else { processDeath(p); hitStopRef.current = 80; }
                      }
                  });
                  if (Math.random() > 0.96) { GameJuice.emitSmoke(ex, ey, e.isDirty ? '#064E3B' : '#444'); }
              }
            }
          };

          const updateBots = (dt) => {
            const s = state.current;
            if (s.freezeTimer > 0) return; 

            const dangerMap = BotAI.buildDangerMap(s);

            s.players.filter(p => p.isBot && p.alive && p.iFrames <= 0 && p.z <= 0 && p.isDiving <= 0).forEach(bot => {
                if (bot.skullTimer > 0) { bot.skullTimer -= dt; if (Math.random() < 0.1) bot.dir = ['up','down','left','right'][Math.floor(Math.random()*4)]; }
                
                if (bot.mount && Math.random() < 0.02) { handleSecondaryAction(bot); return; }
                if (bot.carriedBombId) { handleSecondaryAction(bot); return; }

                const myC = Math.floor(bot.x / TILE_SIZE); const myR = Math.floor(bot.y / TILE_SIZE);
                const inDanger = dangerMap[myR * s.cols + myC] > 0;

                if (inDanger) {
                     const escapePath = BotAI.bfsFindPath(myC, myR, (c,r) => dangerMap[r*s.cols+c] === 0, dangerMap, s, bot, 40, true);
                     if (escapePath && escapePath.length > 0) { bot.target = escapePath[0]; movePlayerTowards(bot, bot.target.c, bot.target.r, dt); } 
                     else { bot.target = null; bot.moving = false; }
                     return;
                }

                bot.botTimer = (bot.botTimer || 0) - dt; 
                if (bot.botTimer > 0) {
                    if (bot.target && dangerMap[bot.target.r * s.cols + bot.target.c] === 0) { movePlayerTowards(bot, bot.target.c, bot.target.r, dt); return; } 
                    else { bot.botTimer = 0; }
                }
                bot.botTimer = 60 + Math.random() * 60; 

                let aliveEnemies = s.players.filter(p => p.alive && p.id !== bot.id && (!s.mode.isTeam || p.team !== bot.team));
                
                if (bot.botPersonality === 'aggressive') aliveEnemies.sort((a,b) => Math.hypot(a.x-bot.x, a.y-bot.y) - Math.hypot(b.x-bot.x, b.y-bot.y));
                else if (bot.botPersonality === 'erratic') aliveEnemies.sort(() => Math.random() - 0.5);

                const enemyVeryNear = aliveEnemies.some(p => Math.abs(Math.floor(p.x/TILE_SIZE)-myC) + Math.abs(Math.floor(p.y/TILE_SIZE)-myR) <= 2);
                
                if (enemyVeryNear && Math.random() < 0.2 && bot.botPersonality !== 'aggressive') {
                     const dirs = [{c:0,r:1},{c:0,r:-1},{c:1,r:0},{c:-1,r:0}].sort(() => Math.random() - 0.5);
                     for(let d of dirs) {
                         if (BotAI.getWalkable(myC+d.c, myR+d.r, s, bot, myC, myR) && dangerMap[(myR+d.r)*s.cols+(myC+d.c)] === 0) { bot.target = {c: myC+d.c, r: myR+d.r}; return; }
                     }
                }

                const isAdjacentToSoft = [[0,1],[0,-1],[1,0],[-1,0]].some(([dc,dr]) => {
                    const tC = myC+dc, tR = myR+dr; return tC>0 && tC<s.cols && tR>0 && tR<s.rows && s.board[tR*s.cols+tC] === 2;
                });
                
                const enemyInBlast = aliveEnemies.some(p => {
                    const eC = Math.floor(p.x/TILE_SIZE); const eR = Math.floor(p.y/TILE_SIZE);
                    if (myC !== eC && myR !== eR) return false; 
                    const dist = Math.abs(myC - eC) + Math.abs(myR - eR); if (dist > bot.range) return false;
                    const dx = Math.sign(eC - myC); const dy = Math.sign(eR - myR);
                    for (let i = 1; i < dist; i++) { if (s.board[(myR + dy*i)*s.cols + (myC + dx*i)] !== 0) return false; }
                    return true;
                });

                if (s.boss && s.boss.active && Math.random() < 0.5) {
                     const bC = Math.floor(s.boss.x/TILE_SIZE); const bR = Math.floor(s.boss.y/TILE_SIZE);
                     if (Math.abs(myC - bC) < 3 && Math.abs(myR - bR) < 3) {
                         if (BotAI.isSafeToDropBomb(bot, s)) { handleBombDrop(bot); bot.target = null; bot.botTimer = 0; return; }
                     }
                }

                if ((isAdjacentToSoft || enemyInBlast || (enemyVeryNear && Math.random() < 0.4)) && Math.random() < bot.botAggro) {
                    if (BotAI.isSafeToDropBomb(bot, s)) { handleBombDrop(bot); bot.target = null; bot.botTimer = 0; return; }
                }

                let path = BotAI.bfsFindPath(myC, myR, (c,r) => {
                    if (s.powerups.some(pu => pu.c === c && pu.r === r && !pu.isFlying)) return true;
                    const hasLosToEnemy = aliveEnemies.some(p => {
                        const eC = Math.floor(p.x/TILE_SIZE); const eR = Math.floor(p.y/TILE_SIZE);
                        if (c !== eC && r !== eR) return false;
                        const dist = Math.abs(c - eC) + Math.abs(r - eR); if (dist > bot.range) return false;
                        const dx = Math.sign(eC - c); const dy = Math.sign(eR - r);
                        for (let i = 1; i <= dist; i++) {
                            const checkC = c + dx*i; const checkR = r + dy*i;
                            if (checkC === eC && checkR === eR) return true; 
                            if (s.board[checkR*s.cols + checkC] !== 0) return false; 
                        }
                        return true;
                    });
                    return hasLosToEnemy && BotAI.isSafeToDropBombAt(c, r, bot, s);
                }, dangerMap, s, bot, 60);

                if (!path) {
                    path = BotAI.bfsFindPath(myC, myR, (c,r) => {
                        const isAdj = [[0,1],[0,-1],[1,0],[-1,0]].some(([dc,dr]) => {
                            const tC = c+dc, tR = r+dr; return tC>0 && tC<s.cols && tR>0 && tR<s.rows && s.board[tR*s.cols+tC] === 2;
                        });
                        return isAdj && BotAI.isSafeToDropBombAt(c, r, bot, s);
                    }, dangerMap, s, bot, 40);

                    if (!path) path = BotAI.bfsFindPath(myC, myR, (c,r) => {
                            return [[0,1],[0,-1],[1,0],[-1,0]].some(([dc,dr]) => {
                                const tC = c+dc, tR = r+dr; return tC>0 && tC<s.cols && tR>0 && tR<s.rows && s.board[tR*s.cols+tC] === 2;
                            });
                    }, dangerMap, s, bot, 30);
                }

                if (path && path.length > 0) { bot.target = path[0]; movePlayerTowards(bot, bot.target.c, bot.target.r, dt); } 
                else { 
                    bot.target = null; const targetX = myC * TILE_SIZE + TILE_SIZE/2; const targetY = myR * TILE_SIZE + TILE_SIZE/2;
                    if (Math.abs(bot.x - targetX) > 1 || Math.abs(bot.y - targetY) > 1) { bot.moving = true; bot.x += (targetX - bot.x) * 0.3; bot.y += (targetY - bot.y) * 0.3; } 
                    else { bot.moving = false; bot.x = targetX; bot.y = targetY; }
                }
            });
          };

          const movePlayerTowards = (p, tc, tr, dt) => {
              if (p.z > 0 || p.isFlying) return;
              const targetX = tc * TILE_SIZE + TILE_SIZE/2; const targetY = tr * TILE_SIZE + TILE_SIZE/2;
              let dx = targetX - p.x; let dy = targetY - p.y;
              
              const speedMod = (p.skullTimer > 0 ? (Math.random() > 0.5 ? 0.4 : 1.6) : 1.0) * (p.isDiving > 0 ? 2.0 : 1.0);
              const moveAmt = (p.speed * speedMod) * (dt/16);
              
              if (Math.abs(dx) > 1 || Math.abs(dy) > 1) {
                  p.moving = true;
                  if (Math.abs(dx) > moveAmt) p.x += Math.sign(dx) * moveAmt; else p.x = targetX;
                  if (Math.abs(dy) > moveAmt) p.y += Math.sign(dy) * moveAmt; else p.y = targetY;
                  p.dir = Math.abs(dx)>Math.abs(dy) ? (dx>0?'right':'left') : (dy>0?'down':'up');

                  if (p.isDiving <= 0) GameJuice.emitDust(p.x, p.y);

                  if (p.hasKick || p.mount === 17) {
                     const s = state.current;
                     const myC = Math.floor(p.x/TILE_SIZE); const myR = Math.floor(p.y/TILE_SIZE);
                     const hitBomb = s.bombs.find(b => b.c===myC && b.r===myR && b.dx===0 && b.dy===0 && !b.isFlying && !b.carriedBy && !b.ignoredBy?.includes(p.id));
                     if (hitBomb) {
                         if (Math.abs(dx) > Math.abs(dy)) { hitBomb.dx = dx > 0 ? 1 : -1; hitBomb.dy = 0; }
                         else { hitBomb.dy = dy > 0 ? 1 : -1; hitBomb.dx = 0; }
                         Sfx.playDrop(); 
                     }
                  }
              } else { p.moving = false; p.x = targetX; p.y = targetY; }
          };

          const handlePlayerInput = (dt) => {
            const s = state.current; 
            let p;
            if (networkState === 'client') { p = s.players.find(pl => pl.uid === user?.uid) || s.players[0]; } else { p = s.players[0]; }
            
            if (!p || !p.alive || s.freezeTimer > 0 || p.isFlying || p.z > 0) return; 

            if (p.skullTimer > 0) p.skullTimer -= dt;

            let kx = 0, ky = 0;
            if (keys.current['w'] || keys.current['arrowup'] || touchDpad.current.y === -1) ky -= 1;
            if (keys.current['s'] || keys.current['arrowdown'] || touchDpad.current.y === 1) ky += 1;
            if (keys.current['a'] || keys.current['arrowleft'] || touchDpad.current.x === -1) kx -= 1;
            if (keys.current['d'] || keys.current['arrowright'] || touchDpad.current.x === 1) kx += 1;
            
            if (p.skullTimer > 0 && Math.floor(p.skullTimer / 1000) % 2 === 0) { kx = -kx; ky = -ky; }

            if (kx !== 0 && ky === 0) { const targetY = Math.floor(p.y / TILE_SIZE) * TILE_SIZE + TILE_SIZE/2; p.y += (targetY - p.y) * 0.2; }
            if (ky !== 0 && kx === 0) { const targetX = Math.floor(p.x / TILE_SIZE) * TILE_SIZE + TILE_SIZE/2; p.x += (targetX - p.x) * 0.2; }
            if (kx !== 0 && ky !== 0) { kx *= 0.707; ky *= 0.707; }

            const speedMod = (p.skullTimer > 0 ? 0.6 : 1.0) * (p.isDiving > 0 ? 2.0 : 1.0);
            const moveX = kx * (p.speed * speedMod) * (dt/16); const moveY = ky * (p.speed * speedMod) * (dt/16);

            p.moving = (kx !== 0 || ky !== 0);
            if (ky < 0) p.dir = 'up'; else if (ky > 0) p.dir = 'down'; else if (kx < 0) p.dir = 'left'; else if (kx > 0) p.dir = 'right';
            if (p.moving && p.isDiving <= 0) GameJuice.emitDust(p.x, p.y);

            const pSize = 24; let newX = p.x + moveX; let newY = p.y + moveY;

            const checkCollision = (nx, ny) => {
              const left = nx - pSize/2, right = nx + pSize/2, top = ny - pSize/2, bottom = ny + pSize/2;
              for (let r = Math.floor(top/TILE_SIZE); r <= Math.floor(bottom/TILE_SIZE); r++) {
                for (let c = Math.floor(left/TILE_SIZE); c <= Math.floor(right/TILE_SIZE); c++) {
                  if (s.board[r * s.cols + c] === 1) return true;
                  if (!p.isGhost && p.isDiving <= 0 && s.board[r * s.cols + c] === 2) return true;
                  
                  if (s.boss && s.boss.active) {
                     const bC = Math.floor(s.boss.x/TILE_SIZE); const bR = Math.floor(s.boss.y/TILE_SIZE);
                     if (c >= bC && c <= bC+1 && r >= bR && r <= bR+1) return true; 
                  }

                  const solidBomb = s.bombs.find(ob => ob.c === c && ob.r === r && !ob.isFlying && !ob.carriedBy);
                  if (solidBomb && p.isDiving <= 0) {
                     if (solidBomb.ignoredBy?.includes(p.id)) continue; 
                     if ((p.hasKick || p.mount === 17) && p.moving && solidBomb.dx===0 && solidBomb.dy===0) {
                        if (Math.abs(kx) > 0 && Math.abs(ny - solidBomb.py) < 15) { solidBomb.dx = kx > 0 ? 1 : -1; solidBomb.dy = 0; Sfx.playDrop(); }
                        else if (Math.abs(ky) > 0 && Math.abs(nx - solidBomb.px) < 15) { solidBomb.dy = ky > 0 ? 1 : -1; solidBomb.dx = 0; Sfx.playDrop(); }
                     }
                     return true; 
                  }
                }
              }
              return false;
            };

            const slideOff = 18; 
            if (moveX !== 0) {
              if (!checkCollision(newX, p.y)) p.x = newX;
              else if (!checkCollision(newX, p.y - slideOff)) p.y -= (p.speed*speedMod)*(dt/16);
              else if (!checkCollision(newX, p.y + slideOff)) p.y += (p.speed*speedMod)*(dt/16);
            }
            if (moveY !== 0) {
              if (!checkCollision(p.x, newY)) p.y = newY;
              else if (!checkCollision(p.x - slideOff, newY)) p.x -= (p.speed*speedMod)*(dt/16);
              else if (!checkCollision(p.x + slideOff, newY)) p.x += (p.speed*speedMod)*(dt/16);
            }
            
            p.x = Math.max(pSize/2, Math.min(s.width - pSize/2, p.x));
            p.y = Math.max(pSize/2, Math.min(s.height - pSize/2, p.y));

            if (networkState === 'client' && user) {
                if ((keys.current[' '] || actionPrimaryBtn.current) && (!p.lastBombReq || Date.now() - p.lastBombReq > 200)) {
                   setDoc(doc(db, 'artifacts', appId, 'public', 'data', `inputs_${roomId}`, user.uid), { action: 'bomb', t: Date.now() }, {merge:true});
                   p.lastBombReq = Date.now(); keys.current[' '] = false; actionPrimaryBtn.current = false;
                }
                if ((keys.current.q || actionSecondaryBtn.current) && (!p.lastSecReq || Date.now() - p.lastSecReq > 250)) {
                   setDoc(doc(db, 'artifacts', appId, 'public', 'data', `inputs_${roomId}`, user.uid), { action: 'special', t: Date.now() }, {merge:true});
                   p.lastSecReq = Date.now(); keys.current.q = false; actionSecondaryBtn.current = false;
                }
                if (p.moving && Date.now() - p.lastSync > 100) {
                     setDoc(doc(db, 'artifacts', appId, 'public', 'data', `inputs_${roomId}`, user.uid), { x: p.x, y: p.y, dir: p.dir }, {merge:true});
                     p.lastSync = Date.now();
                }
                return; 
            }

            if ((keys.current[' '] || actionPrimaryBtn.current) && (!p.lastBombReq || Date.now() - p.lastBombReq > 200)) {
               handleBombDrop(p); p.lastBombReq = Date.now(); keys.current[' '] = false; actionPrimaryBtn.current = false;
            }
            if ((keys.current.q || actionSecondaryBtn.current) && (!p.lastSecReq || Date.now() - p.lastSecReq > 250)) {
               handleSecondaryAction(p); p.lastSecReq = Date.now(); keys.current.q = false; actionSecondaryBtn.current = false;
            }
          };

          const handleItemCollection = () => {
             const s = state.current;
             s.players.forEach(p => {
                 if(!p.alive || p.iFrames > 0 || p.z > 0) return;
                 for (let i = s.powerups.length - 1; i >= 0; i--) {
                    const pu = s.powerups[i];
                    if (!pu.isFlying && Math.hypot(p.x - pu.px, p.y - pu.py) < 30) { 
                        let effect = pu.type;
                        if (effect.id === 15) effect = Object.values(POWERUPS)[Math.floor(Math.random()*16)];
                        let audioIntensity = 1;

                        switch(effect.id) {
                          case 1: p.maxBombs = Math.min(10, p.maxBombs + 1); audioIntensity = p.maxBombs; break;
                          case 2: p.range = Math.min(12, p.range + 1); audioIntensity = p.range; break;
                          case 3: p.speed = Math.min(9.0, p.speed + 0.6); audioIntensity = p.speed; break;
                          case 4: p.hasKick = true; break;
                          case 5: p.hasPunch = true; break;
                          case 6: p.hasMega = true; p.hasDirty = false; break;
                          case 7: p.hasDirty = true; p.hasMega = false; break;
                          case 8: p.skullTimer = 8000; break;
                          case 9: p.hasShield = true; break;
                          case 10: p.isGhost = true; break;
                          case 11: p.hasGlove = true; break; 
                          case 12: p.range = 15; audioIntensity = 15; break;
                          case 13: p.lives++; break;
                          case 14: s.players.forEach(op => { if(op.id !== p.id && (!s.mode.isTeam || op.team !== p.team)) op.freezeTimer = 4000; }); break;
                          case 16: p.mount = 16; break; 
                          case 17: p.mount = 17; p.hasPunch = true; p.hasKick = true; break; 
                          case 18: p.mount = 18; break; 
                          case 19: p.mount = 19; break; 
                        }
                        
                        Sfx.playPowerup(effect.id, audioIntensity); 
                        GameJuice.emitText(p.x, p.y-20, effect.text, effect.bg);
                        s.powerups.splice(i, 1);
                    }
                 }
             });
          };

          const renderGame = () => {
            const ctx = ctxRef.current;
            if (!ctx) return;
            
            try {
                const s = state.current; const width = s.width; const height = s.height; const currentTheme = s.theme;

                if (s.bgNeedsRedraw && bgCanvasRef.current) {
                    const bgCtx = bgCanvasRef.current.getContext('2d');
                    bgCtx.save();
                    bgCtx.scale(state.current.currentRes, state.current.currentRes);
                    Renderer.drawFloor(bgCtx, s.cols, s.rows, currentTheme);
                    for (let r = 0; r < s.rows; r++) {
                        for (let c = 0; c < s.cols; c++) {
                            const t = s.board[r * s.cols + c];
                            const isBoundary = (c === 0 || c === s.cols - 1 || r === 0 || r === s.rows - 1);
                            if (t === 1) Renderer.drawHardBlock(bgCtx, c*TILE_SIZE, r*TILE_SIZE, isBoundary, currentTheme);
                            else if (t === 2) Renderer.drawSoftBlock(bgCtx, c*TILE_SIZE, r*TILE_SIZE, currentTheme);
                        }
                    }
                    bgCtx.restore();
                    s.bgNeedsRedraw = false;
                }

                ctx.save();
                ctx.scale(state.current.currentRes, state.current.currentRes);
                ctx.clearRect(0, 0, width, height);

                if (GameJuice.shakeIntensity > 0) ctx.translate((Math.random()-0.5)*GameJuice.shakeIntensity, (Math.random()-0.5)*GameJuice.shakeIntensity); 

                if (bgCanvasRef.current) ctx.drawImage(bgCanvasRef.current, 0, 0, width, height);

                s.fallingBlocks.forEach(b => { ctx.save(); ctx.translate(b.c*TILE_SIZE, b.r*TILE_SIZE + b.y); Renderer.drawHardBlock(ctx, 0, 0, false, currentTheme); ctx.restore(); });
                s.powerups.forEach(pu => Renderer.drawItemBox(ctx, pu.type, pu.px, pu.py, pu.z, s.frame));
                s.bombs.filter(b=>!b.carriedBy).forEach(b => Renderer.drawBomb(ctx, b));

                if (s.boss) Renderer.drawBoss(ctx, s.boss, s.frame);

                s.explosions.forEach(e => {
                   const sizeMod = Math.sin((e.timer / e.maxTimer) * Math.PI); 
                   if (sizeMod <= 0) return;
                   const padding = (1 - sizeMod) * (TILE_SIZE / 2); const bx = e.c * TILE_SIZE + padding; const by = e.r * TILE_SIZE + padding; const bSize = TILE_SIZE - (padding * 2);
                   
                   ctx.globalCompositeOperation = 'screen';
                   ctx.fillStyle = e.isDirty ? '#059669' : (e.isMega ? '#C026D3' : '#EA580C'); ctx.fillRect(bx, by, bSize, bSize);
                   if (sizeMod > 0.4) {
                       ctx.fillStyle = e.isDirty ? '#34D399' : (e.isMega ? '#E879F9' : '#FBBF24');
                       const p2 = padding + (bSize * 0.15); const s2 = bSize * 0.7; ctx.fillRect(e.c*TILE_SIZE + p2, e.r*TILE_SIZE + p2, s2, s2);
                       ctx.fillStyle = '#FFF'; const p3 = padding + (bSize * 0.35); const s3 = bSize * 0.3; ctx.fillRect(e.c*TILE_SIZE + p3, e.r*TILE_SIZE + p3, s3, s3);
                   }
                   ctx.globalCompositeOperation = 'source-over';
                });

                [...s.players].sort((a,b)=>a.y - b.y).forEach(p => Renderer.drawPlayer(ctx, p, s.frame));
                s.bombs.filter(b=>b.carriedBy).forEach(b => Renderer.drawBomb(ctx, b));

                GameJuice.shockwaves.forEach(sw => {
                    ctx.beginPath(); ctx.arc(sw.x, sw.y, sw.radius, 0, Math.PI*2);
                    ctx.lineWidth = 4 * sw.life; ctx.strokeStyle = sw.color; ctx.globalAlpha = sw.life;
                    ctx.stroke(); ctx.globalAlpha = 1.0;
                });

                GameJuice.particles.forEach(p => {
                   if (p.text) { 
                       ctx.fillStyle = p.color; ctx.font='bold 14px "Press Start 2P", monospace'; ctx.textAlign='center'; 
                       ctx.lineWidth=3; ctx.strokeStyle='#000'; ctx.strokeText(p.text, p.x, p.y); ctx.fillText(p.text, p.x, p.y); 
                   } else if (p.type === 'wood') {
                       ctx.save(); ctx.translate(p.x, p.y); ctx.rotate(p.rot); ctx.fillStyle = p.color; ctx.fillRect(-p.size/2, -p.size/2, p.size, p.size); ctx.restore();
                   } else { 
                       ctx.fillStyle = p.color; let alpha = Math.max(0, p.life/p.maxLife); if (p.type === 'smoke' || p.type === 'dust') alpha *= 0.35; 
                       ctx.globalAlpha = alpha; ctx.beginPath(); ctx.arc(p.x, p.y, p.size || 4, 0, Math.PI*2); ctx.fill(); ctx.globalAlpha = 1.0;
                   }
                });

                const gradient = ctx.createRadialGradient(width/2, height/2, height/2, width/2, height/2, width);
                gradient.addColorStop(0, 'transparent'); gradient.addColorStop(1, 'rgba(0,0,0,0.6)');
                ctx.fillStyle = gradient; ctx.fillRect(0, 0, width, height);

                if (s.freezeTimer > 0) {
                    ctx.fillStyle = 'rgba(0, 255, 255, 0.15)'; ctx.fillRect(0,0,width, height);
                    ctx.fillStyle = '#00FFFF'; ctx.font='bold 30px "Press Start 2P"'; ctx.textAlign='center'; 
                    ctx.lineWidth=6; ctx.strokeStyle='#000'; ctx.strokeText("TIME FROZEN", width/2, height/2); ctx.fillText("TIME FROZEN", width/2, height/2);
                }

                if (s.winner) {
                  ctx.fillStyle = 'rgba(0,0,0,0.85)'; ctx.fillRect(0, 0, width, height);
                  const scale = 1 + Math.sin(Date.now() / 200) * 0.05; ctx.save(); ctx.translate(width/2, height/2); ctx.scale(scale, scale);
                  
                  ctx.fillStyle = s.winner === 'DRAW' ? '#AAA' : (s.winner === 'BOSS DEFEATED!' ? '#10B981' : '#FFD700'); 
                  ctx.font = '36px "Press Start 2P", monospace'; ctx.textAlign = 'center'; ctx.textBaseline='middle';
                  const text = s.winner === 'DRAW' ? 'DRAW!' : s.winner;
                  ctx.lineWidth = 6; ctx.strokeStyle = '#000'; ctx.strokeText(text, 0, -10); ctx.fillText(text, 0, -10);
                  ctx.font = '12px "Press Start 2P", monospace'; ctx.fillStyle = '#FFF'; ctx.lineWidth = 3; ctx.strokeText("TAP TO CONTINUE", 0, 40); ctx.fillText("TAP TO CONTINUE", 0, 40);
                  ctx.restore();
                }
                
                ctx.restore();
            } catch(err) { console.error("Render Loop Error:", err); }
          };

          const gameLoop = (time) => {
            if (!lastTimeRef.current) lastTimeRef.current = time;
            let dt = time - lastTimeRef.current; lastTimeRef.current = time;
            if (dt > 30) dt = 30; 

            if (viewRef.current === 'playing' && state.current) {
               if (hitStopRef.current > 0) { hitStopRef.current -= dt; } 
               else {
                   const s = state.current; s.frame++;
                   
                   // UI Sync Tick - Update React DOM to keep UI (timer, controls) in sync with game loop
                   if (s.frame % 15 === 0) { setUiTick(s.frame); }
                   
                   if (!s.winner) {
                       if (networkState === 'host') {
                            Object.entries(remoteInputsRef.current).forEach(([uid, input]) => {
                                const p = s.players.find(pl => pl.uid === uid);
                                if (p && p.alive) {
                                    if (input.action === 'bomb') handleBombDrop(p);
                                    if (input.action === 'special') handleSecondaryAction(p);
                                    if (input.x) { p.x = input.x; p.y = input.y; p.dir = input.dir; p.moving = true; }
                                }
                            });
                            remoteInputsRef.current = {}; 
                       }

                       handlePlayerInput(dt); 
                       
                       if (networkState !== 'client') { updateBots(dt); updateEntities(dt); handleItemCollection(); }
                       GameJuice.update(dt);
                       
                       if (s.mode.id === 'boss') {
                           if (s.boss && !s.boss.active) { s.winTimer += dt; if (s.winTimer > 2000) s.winner = 'BOSS DEFEATED!'; } 
                           else if (!s.players.some(p => p.alive)) { s.winTimer += dt; if (s.winTimer > 2000) s.winner = 'GAME OVER'; }
                       } else {
                           if (s.mode.isTeam) {
                               const aliveTeams = new Set(s.players.filter(p=>p.alive).map(p=>p.team));
                               if (aliveTeams.size <= 1 && s.timer < s.mode.timer - 5) {
                                   s.winTimer += dt; if (s.winTimer > 1500) s.winner = aliveTeams.size===1 ? `TEAM ${Array.from(aliveTeams)[0]} WINS!` : 'DRAW';
                               } else { s.winTimer = 0; }
                           } else {
                               let activeCount = 0; let lastAlive = null;
                               for (let i=0; i<s.players.length; i++) { if (s.players[i].alive) { activeCount++; lastAlive = s.players[i]; } }
                               if (activeCount <= 1 && s.timer < s.mode.timer - 5) {
                                   s.winTimer += dt; if (s.winTimer > 1500) s.winner = activeCount === 1 ? lastAlive.name : 'DRAW'; 
                               } else { s.winTimer = 0; }
                           }
                       }

                       if (networkState === 'host' && user && roomId) {
                           syncTimerRef.current += dt;
                           if (syncTimerRef.current > 150) {
                               syncTimerRef.current = 0;
                               setDoc(doc(db, 'artifacts', appId, 'public', 'data', 'rooms', roomId), {
                                   gameState: JSON.stringify({ players: s.players, bombs: s.bombs, explosions: s.explosions, powerups: s.powerups, fallingBlocks: s.fallingBlocks, timer: s.timer, winner: s.winner, boss: s.boss })
                               }, {merge:true});
                           }
                       }
                   }
               }
               renderGame();
            } else if (viewRef.current === 'customize' && canvasRef.current) {
               const ctx = canvasRef.current.getContext('2d');
               ctx.save();
               ctx.scale(RES, RES);
               ctx.clearRect(0,0,200,200);
               const t = Date.now();
               const demoP = { alive: true, iFrames: 0, isGhost: false, x: 100, y: 120, moving: true, dir: 'down', colorIdx: 0, body: customRef.current.color, limb: customRef.current.limb, visor: '#00FFFF', helmet: customRef.current.helmet, name: '' };
               Renderer.drawPlayer(ctx, demoP, t / 16);
               ctx.restore();
            }
            
            if (viewRef.current === 'playing' || viewRef.current === 'customize') {
                reqRef.current = requestAnimationFrame(gameLoop);
            }
          };

          useEffect(() => { 
              viewRef.current = view; 
              if (reqRef.current) { cancelAnimationFrame(reqRef.current); reqRef.current = null; }
              if (view === 'playing' || view === 'customize') {
                 lastTimeRef.current = performance.now(); reqRef.current = requestAnimationFrame(gameLoop);
              } else if (view === 'menu' || view === 'lobby' || view === 'editor') {
                 Sfx.updateFuseSound(0); 
              }
              return () => { if (reqRef.current) { cancelAnimationFrame(reqRef.current); reqRef.current = null; } }
          }, [view]);

          const p1 = state.current.players?.[0] || {};
          const hasSecondaryAction = p1.hasPunch || p1.hasGlove || p1.mount;

          return (
            <div className="flex flex-col h-[100dvh] w-screen bg-black text-white overflow-hidden select-none touch-none font-sans relative">
              
              {/* GLOBAL FULLSCREEN BUTTON FOR MENU */}
              {view !== 'playing' && (
                  <button onClick={toggleFullscreen} className="absolute top-4 right-4 z-50 p-2 bg-[#1E293B] border-2 border-[#38BDF8] rounded text-white arcade-font text-[8px] sm:text-[10px] shadow-lg">
                      {isFullscreen ? '🗗 EXIT FS' : '🖵 FULLSCREEN'}
                  </button>
              )}

              {view === 'menu' && (
                <div className="flex-1 flex flex-col justify-center items-center p-4" style={{background: 'radial-gradient(circle, #1E293B 0%, #000 100%)'}}>
