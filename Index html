              const rect = canvasRef.current.getBoundingClientRect();
              const scaleX = (editorMap.cols * TILE_SIZE) / rect.width; 
              const scaleY = (editorMap.rows * TILE_SIZE) / rect.height;
              const x = (e.clientX - rect.left) * scaleX; const y = (e.clientY - rect.top) * scaleY;
              const c = Math.floor(x / TILE_SIZE); const r = Math.floor(y / TILE_SIZE);
              
              if (c>0 && c<editorMap.cols-1 && r>0 && r<editorMap.rows-1) {
                  const newBoard = [...editorMap.board]; newBoard[r * editorMap.cols + c] = editorTool;
                  setEditorMap({ ...editorMap, board: newBoard });
