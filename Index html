                    speed: isSniper ? 6.0 : (isBot ? 4.2 * mode.botSpeed : 4.8), maxBombs: 1, range: isSniper ? 15 : 1, mount: null,
                    hasDirty: false, hasMega: false, hasKick: false, hasPunch: false, hasGlove: false, hasShield: false, isGhost: false,
