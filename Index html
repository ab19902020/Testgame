                  }
                  
                  const sPos = startPos[idx] || { c: 1 + Math.floor(Math.random()*(cols-2)), r: 1 + Math.floor(Math.random()*(rows-2)) };

                  return {
                    id, uid, isBot, colorIdx: idx, alive: true, lives: mode.startLives, iFrames: 0,
