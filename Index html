              if (!ctx || !editorMap) return;
              const width = editorMap.cols * TILE_SIZE * RES;
              const height = editorMap.rows * TILE_SIZE * RES;

              ctx.save();
              ctx.scale(RES, RES);
              ctx.clearRect(0, 0, width, height);
              Renderer.drawFloor(ctx, editorMap.cols, editorMap.rows, MAP_THEMES.CLASSIC);
              
              for (let r = 0; r < editorMap.rows; r++) {
                  for (let c = 0; c < editorMap.cols; c++) {
                      const t = editorMap.board[r * editorMap.cols + c];
                      const isBoundary = (c === 0 || c === editorMap.cols - 1 || r === 0 || r === editorMap.rows - 1);
                      if (t === 1) Renderer.drawHardBlock(ctx, c*TILE_SIZE, r*TILE_SIZE, isBoundary, MAP_THEMES.CLASSIC);
                      else if (t === 2) Renderer.drawSoftBlock(ctx, c*TILE_SIZE, r*TILE_SIZE, MAP_THEMES.CLASSIC);
                  }
              }
              
              ctx.strokeStyle = 'rgba(255,255,255,0.1)';
              ctx.lineWidth = 1;
              for (let r = 0; r <= editorMap.rows; r++) { ctx.beginPath(); ctx.moveTo(0, r*TILE_SIZE); ctx.lineTo(editorMap.cols*TILE_SIZE, r*TILE_SIZE); ctx.stroke(); }
              for (let c = 0; c <= editorMap.cols; c++) { ctx.beginPath(); ctx.moveTo(c*TILE_SIZE, 0); ctx.lineTo(c*TILE_SIZE, editorMap.rows*TILE_SIZE); ctx.stroke(); }
