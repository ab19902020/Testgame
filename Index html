            if (s.boss && s.boss.active && s.boss.state === 'charge_laser') {
                for(let c=0; c<s.cols; c++) map[Math.floor(s.boss.y/TILE_SIZE) * s.cols + c] = 2;
                for(let r=0; r<s.rows; r++) map[r * s.cols + Math.floor(s.boss.x/TILE_SIZE)] = 2;
