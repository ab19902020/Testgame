                    botPersonality: isBot ? ['aggressive','tactical','erratic'][Math.floor(Math.random()*3)] : null
                  };
                };

                const players = [];
                let totalPlayersNeeded = isNetworked ? Math.max(networkPlayersList.length, playerCount) : playerCount;
                totalPlayersNeeded = Math.min(totalPlayersNeeded, mapDef.max);

                if (isNetworked) {
                     networkPlayersList.forEach((lp, i) => {
