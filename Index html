               const demoP = { alive: true, iFrames: 0, isGhost: false, x: 100, y: 120, moving: true, dir: 'down', colorIdx: 0, body: customRef.current.color, limb: customRef.current.limb, visor: '#00FFFF', helmet: customRef.current.helmet, name: '' };
