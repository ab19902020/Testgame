            if (!bot.isGhost && s.board[r*s.cols + c] === 2) return false;
            if (s.bombs.some(b => b.c === c && b.r === r && b.dx === 0 && b.dy === 0 && !b.isFlying && !b.carriedBy && !(c === ignoreBombC && r === ignoreBombR))) return false;
            if (s.boss && s.boss.active) { 
                 const bc = Math.floor(s.boss.x/TILE_SIZE); const br = Math.floor(s.boss.y/TILE_SIZE);
                 if (c >= bc && c <= bc+1 && r >= br && r <= br+1) return false;
            }
            return true;
          },
          buildDangerMap: (s, additionalBombs = []) => {
            let map = Array(s.cols * s.rows).fill(0); 
