                           let nc = b.c + d.x*i, nr = b.r + d.y*i;
                           if(nc<=0 || nc>=s.cols-1 || nr<=0 || nr>=s.rows-1 || s.board[nr*s.cols + nc] === 1) break; 
                           map[nr*s.cols + nc] = Math.max(map[nr*s.cols + nc], threatLevel);
                           if(s.board[nr*s.cols + nc] === 2) break; 
                        }
                    });
                }
            });
            return map;
          },
          bfsFindPath: (startC, startR, targetCond, dangerMap, s, bot, maxDepth = 40, ignoreDanger = false) => {
            if (targetCond(startC, startR)) return []; 
            let queue = [{c: startC, r: startR, path: []}]; let visited = new Set([`${startC},${startR}`]);
            const dirs = [[0,-1],[0,1],[-1,0],[1,0]].sort(() => Math.random() - 0.5);
            while (queue.length > 0) {
