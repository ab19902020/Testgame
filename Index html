                if(b.c >= 0 && b.c < s.cols && b.r >= 0 && b.r < s.rows) map[b.r*s.cols + b.c] = Math.max(map[b.r*s.cols + b.c], threatLevel); 
                if (b.isDirty || b.isMega) {
                    const rRad = b.isDirty ? Math.min(6, 3 + Math.floor(b.range / 2)) : Math.min(4, b.range); 
                    for(let r = -rRad; r <= rRad; r++) for(let c = -rRad; c <= rRad; c++) {
