                         players.push(createPlayer(`p${i+1}`, false, i, lp.name, lp.uid, team));
                     });
                     for (let i = networkPlayersList.length; i < totalPlayersNeeded; i++) {
                         const team = mode.id === 'boss' ? 1 : (mode.isTeam ? (i%2)+1 : null);
                         players.push(createPlayer(`b${i+1}`, true, i, `BOT ${i}`, null, team));
                     }
                } else {
                     const humanTeam = mode.id === 'boss' ? 1 : (mode.isTeam ? 1 : null);
                     players.push(createPlayer('p1', false, 0, 'YOU', user?.uid, humanTeam));
                     for (let i = 1; i < totalPlayersNeeded; i++) {
                         const team = mode.id === 'boss' ? 1 : (mode.isTeam ? (i%2)+1 : null);
                         players.push(createPlayer(`b${i}`, true, i, `BOT ${i}`, null, team));
                     }
                }

                let boss = null;
                if (mode.id === 'boss') boss = { active: true, x: (cols/2)*TILE_SIZE, y: (rows/2)*TILE_SIZE, vx: 0, vy: 0, hp: 50, maxHp: 50, state: 'chase', stateTimer: 0, speed: 2.0, targetId: null };

                const cRes = Math.min(RES, Math.floor(MAX_CANVAS_DIMENSION / Math.max(cols * TILE_SIZE, rows * TILE_SIZE)));

                state.current = {
                  mode, cols, rows, width: cols * TILE_SIZE, height: rows * TILE_SIZE, theme, currentRes: cRes,
                  board, players, bombs: [], explosions: [], powerups: [], hiddenItems, dropCounts: {},
                  timer: mode.timer, winner: null, winTimer: 0, frame: 0, freezeTimer: 0,
                  hurryUpSpiral: spiral, hurryUpIndex: 0, fallingBlocks: [], lastBombCount: 0, bgNeedsRedraw: true, boss
                };
                
                lastTimeRef.current = 0; hitStopRef.current = 0; setView('playing');
                
                if (isNetworked && networkState === 'host' && roomId) {
                    setDoc(doc(db, 'artifacts', appId, 'public', 'data', 'rooms', roomId), { 
                        status: 'playing', 
                        initialBoard: JSON.stringify(board),
                        config: { mode: mode.id, mapSize: mapKey, mapTheme: themeKey } 
                    }, {merge:true});
                }
            } catch(e) { console.error("Init Error:", e); }
          };

