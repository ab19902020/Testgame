              if (p.carriedBombId) { const b = s.bombs.find(bomb => bomb.id === p.carriedBombId); if (b) { b.carriedBy = null; b.z = 0; } p.carriedBombId = null; }

              const scatter = [];
              if (p.maxBombs > 1) scatter.push(POWERUPS.BOMB);
