```html
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
    <title>Blind Rank Pro</title>
    
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    
    <!-- React & ReactDOM -->
    <script src="https://unpkg.com/react@18/umd/react.production.min.js" crossorigin></script>
    <script src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js" crossorigin></script>
    
    <!-- Babel for in-browser JSX compilation -->
    <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>

    <style>
        /* Premium Typography */
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Outfit:wght@400;500;700;800;900&display=swap');
        
        body { margin: 0; padding: 0; background-color: #030305; color: white; overflow: hidden; overscroll-behavior: none; }
        
        .display-font { font-family: 'Outfit', sans-serif; }
        .body-font { font-family: 'Inter', sans-serif; }
        
        /* Glassmorphism & High-End Shadows */
        .glass-premium { 
            background: rgba(255, 255, 255, 0.06); 
            backdrop-filter: blur(24px); 
            -webkit-backdrop-filter: blur(24px);
            border: 1px solid rgba(255, 255, 255, 0.12); 
            box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.3);
        }
        .glass-card {
            background: linear-gradient(145deg, rgba(255,255,255,0.1) 0%, rgba(255,255,255,0.02) 100%);
            backdrop-filter: blur(24px); 
            -webkit-backdrop-filter: blur(24px);
            border: 1px solid rgba(255, 255, 255, 0.2); 
            box-shadow: 0 16px 40px rgba(0, 0, 0, 0.4);
        }
        .glass-panel {
            background: rgba(3, 3, 5, 0.75); 
            backdrop-filter: blur(40px); 
            -webkit-backdrop-filter: blur(40px);
        }
        
        /* Vibrant Ambient Gradients (Tinted instead of opaque) */
        .ambient-sports { background: radial-gradient(circle at 10% 0%, rgba(0, 212, 255, 0.4) 0%, transparent 60%), radial-gradient(circle at 90% 100%, rgba(0, 110, 255, 0.4) 0%, transparent 60%); }
        .ambient-movies { background: radial-gradient(circle at 10% 0%, rgba(255, 184, 0, 0.4) 0%, transparent 60%), radial-gradient(circle at 90% 100%, rgba(255, 61, 90, 0.4) 0%, transparent 60%); }
        .ambient-tv { background: radial-gradient(circle at 10% 0%, rgba(184, 41, 255, 0.4) 0%, transparent 60%), radial-gradient(circle at 90% 100%, rgba(90, 0, 255, 0.4) 0%, transparent 60%); }

        .line-clamp-2 { display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
        
        @keyframes scan { 0%{top:0%} 100%{top:100%} }
        .animate-scan { animation: scan 2.5s cubic-bezier(0.4, 0, 0.2, 1) infinite; }
        @keyframes float { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-8px)} }
        .animate-float { animation: float 3.5s ease-in-out infinite; }
        @keyframes pop { 0%{transform:scale(1)} 50%{transform:scale(1.05)} 100%{transform:scale(1)} }
        .anim-pop { animation: pop 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.275); }
        
        .no-scrollbar::-webkit-scrollbar { display: none; }
        
        /* Safe Area Padding for Modern Phones */
        .pt-safe { padding-top: max(1.5rem, env(safe-area-inset-top)); }
        .pb-safe { padding-bottom: max(1.5rem, env(safe-area-inset-bottom)); }
    </style>
</head>
<body>
    <div id="root"></div>

    <script type="text/babel">
        const { useState, useEffect, useRef, useCallback } = React;

        // ── SVGs ──
        const Icon = ({ path, size = 24, className = "" }) => ( <svg xmlns="http://www.w3.org/2000/svg" width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2.5" strokeLinecap="round" strokeLinejoin="round" className={className} dangerouslySetInnerHTML={{__html: path}} /> );
        const RefreshCw = (p) => <Icon {...p} path='<path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/>'/>;
        const Share2 = (p) => <Icon {...p} path='<circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/>'/>;
        const UserIcon = (p) => <Icon {...p} path='<path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>'/>;
        const CircleIcon = (p) => <Icon {...p} path='<circle cx="12" cy="12" r="10"/>'/>;
        const SquareIcon = (p) => <Icon {...p} path='<rect width="18" height="18" x="3" y="3" rx="2" ry="2"/>'/>;
        const TrophyIcon = (p) => <Icon {...p} path='<path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"/><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"/><path d="M4 22h16"/><path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22"/><path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22"/><path d="M18 2H6v7a6 6 0 0 0 12 0V2Z"/>'/>;
        const Loader2 = (p) => <Icon {...p} path='<path d="M21 12a9 9 0 1 1-6.219-8.56"/>'/>;
        const ChevronRight = (p) => <Icon {...p} path='<path d="m9 18 6-6-6-6"/>'/>;
        const ArrowLeft = (p) => <Icon {...p} path='<path d="m12 19-7-7 7-7"/><path d="M19 12H5"/>'/>;
        const FilterIcon = (p) => <Icon {...p} path='<polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"/>'/>;
        const UsersIcon = (p) => <Icon {...p} path='<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>'/>;
        const StarIcon = (p) => <Icon {...p} path='<polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>'/>;
        const AlertCircle = (p) => <Icon {...p} path='<circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>'/>;
        const PopcornIcon = (p) => <Icon {...p} path='<path d="M4 11h16v9a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2v-9Z"/><path d="M4 11V8.5A2.5 2.5 0 0 1 6.5 6h11A2.5 2.5 0 0 1 20 8.5V11"/><path d="M8.5 6V4.5A2.5 2.5 0 0 1 11 2h2a2.5 2.5 0 0 1 2.5 2.5V6"/><path d="M12 11v10"/><path d="M8 11v10"/><path d="M16 11v10"/>'/>;
        const DownloadIcon = (p) => <Icon {...p} path='<path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/>'/>;
        const TvIcon = (p) => <Icon {...p} path='<rect x="2" y="7" width="20" height="15" rx="2" ry="2"/><polyline points="17 2 12 7 7 2"/>'/>;

        const TMDB_KEY = '3ea9e43d0b879725ac8fda707021e858';

        // Vibrant Theme Colors
        const THEME = {
            sports: { primary: '#00E5FF', secondary: '#0066FF', bg: 'ambient-sports' },
            movies: { primary: '#FFB800', secondary: '#FF3D5A', bg: 'ambient-movies' },
            tv: { primary: '#D946EF', secondary: '#7C3AED', bg: 'ambient-tv' }
        };

        const MOVIE_CATS = [
          { id: 'actors', name: 'HOLLYWOOD ICONS', icon: '🌟', isActorMode: true },
          { id: 'popular', name: 'POPULAR BLOCKBUSTERS', icon: '🔥', endpoint: '/discover/movie?sort_by=popularity.desc&with_original_language=en&without_genres=16' },
          { id: 'top_rated', name: 'TOP RATED OF ALL TIME', icon: '⭐', endpoint: '/discover/movie?sort_by=vote_average.desc&vote_count.gte=4000&with_original_language=en&without_genres=16' },
          { id: 'action', name: 'ACTION & ADVENTURE', icon: '💥', endpoint: '/discover/movie?with_genres=28&sort_by=popularity.desc&with_original_language=en&without_genres=16' },
          { id: 'comedy', name: 'COMEDY CLASSICS', icon: '😂', endpoint: '/discover/movie?with_genres=35&sort_by=popularity.desc&with_original_language=en&without_genres=16' },
          { id: 'horror', name: 'HORROR & THRILLERS', icon: '🔪', endpoint: '/discover/movie?with_genres=27&sort_by=popularity.desc&with_original_language=en&without_genres=16' },
          { id: 'scifi', name: 'SCI-FI & FANTASY', icon: '👽', endpoint: '/discover/movie?with_genres=878&sort_by=popularity.desc&with_original_language=en&without_genres=16' },
          { id: 'animation', name: 'ANIMATED HITS', icon: '🎨', endpoint: '/discover/movie?with_genres=16&sort_by=popularity.desc&with_original_language=en' }
        ];

        const TV_CATS = [
          { id: 'popular', name: 'POPULAR SHOWS', icon: '🔥', endpoint: '/discover/tv?sort_by=popularity.desc&with_original_language=en&without_genres=10763,10764' },
          { id: 'top_rated', name: 'TOP RATED SERIES', icon: '⭐', endpoint: '/discover/tv?sort_by=vote_average.desc&vote_count.gte=1500&with_original_language=en&without_genres=10763,10764' },
          { id: 'drama', name: 'GRIPPING DRAMAS', icon: '🎭', endpoint: '/discover/tv?with_genres=18&sort_by=popularity.desc&with_original_language=en&without_genres=10763,10764' },
          { id: 'comedy', name: 'COMEDY SERIES', icon: '😂', endpoint: '/discover/tv?with_genres=35&sort_by=popularity.desc&with_original_language=en&without_genres=10763,10764' },
          { id: 'scifi', name: 'SCI-FI & FANTASY', icon: '👽', endpoint: '/discover/tv?with_genres=10759,10765&sort_by=popularity.desc&with_original_language=en' },
          { id: 'animation', name: 'ANIMATED SHOWS', icon: '🎨', endpoint: '/discover/tv?with_genres=16&sort_by=popularity.desc&with_original_language=en' }
        ];

        const ACTORS_DATA = [ "Adam Sandler", "Al Pacino", "Andrey Hepburn", "Angelina Jolie", "Anthony Hopkins", "Anya Taylor-Joy", "Arnold Schwarzenegger", "Brad Pitt", "Bruce Lee", "Cate Blanchett", "Charlize Theron", "Christian Bale", "Cillian Murphy", "Clint Eastwood", "Daniel Day-Lewis", "Denzel Washington", "Emma Stone", "Florence Pugh", "Gary Oldman", "Harrison Ford", "Heath Ledger", "Humphrey Bogart", "Jack Nicholson", "Jackie Chan", "Jim Carrey", "Joaquin Phoenix", "Jodie Foster", "Johnny Depp", "Julia Roberts", "Kate Winslet", "Keanu Reeves", "Leonardo DiCaprio", "Margot Robbie", "Marilyn Monroe", "Marlon Brando", "Matt Damon", "Meryl Streep", "Morgan Freeman", "Natalie Portman", "Nicole Kidman", "Robert De Niro", "Robin Williams", "Ryan Gosling", "Samuel L. Jackson", "Sandra Bullock", "Scarlett Johansson", "Sylvester Stallone", "Tom Cruise", "Tom Hanks", "Viola Davis", "Will Smith", "Zendaya" ].sort();

        const SOCCER_LEGENDS_DATA = [ "Thierry Henry", "Dennis Bergkamp", "Patrick Vieira", "Tony Adams", "Ian Wright", "Robert Pires", "David Seaman", "Cesc Fabregas", "Robin van Persie", "Ashley Cole", "Ryan Giggs", "Paul Scholes", "Roy Keane", "Wayne Rooney", "Eric Cantona", "Rio Ferdinand", "Nemanja Vidic", "Peter Schmeichel", "Ruud van Nistelrooy", "David Beckham", "Cristiano Ronaldo", "Frank Lampard", "Didier Drogba", "John Terry", "Petr Cech", "Eden Hazard", "Gianfranco Zola", "Claude Makelele", "Michael Essien", "Steven Gerrard", "Ian Rush", "Kenny Dalglish", "Xabi Alonso", "Sergio Aguero", "David Silva", "Vincent Kompany", "Yaya Toure", "Kevin De Bruyne", "Alan Shearer", "Gareth Bale", "Pele", "Diego Maradona", "Lionel Messi", "Ronaldo", "Ronaldinho", "Zico", "Johan Cruyff", "Zinedine Zidane", "Franz Beckenbauer", "Michel Platini", "Paolo Maldini", "Andres Iniesta", "Xavi", "Gianluigi Buffon", "Iker Casillas", "Andrea Pirlo", "Carles Puyol" ];
        const NBA_LEGENDS_DATA = [ "Michael Jordan", "LeBron James", "Kobe Bryant", "Magic Johnson", "Larry Bird", "Shaquille O'Neal", "Kareem Abdul-Jabbar", "Wilt Chamberlain", "Bill Russell", "Tim Duncan", "Hakeem Olajuwon", "Kevin Durant", "Stephen Curry", "Oscar Robertson", "Jerry West", "Julius Erving", "Karl Malone", "Dirk Nowitzki", "Dwyane Wade", "Kevin Garnett", "Charles Barkley", "David Robinson", "Allen Iverson", "Scottie Pippen", "Patrick Ewing", "Steve Nash", "Jason Kidd", "John Stockton", "Isiah Thomas", "Carmelo Anthony" ];
        const NFL_LEGENDS_DATA = [ "Tom Brady", "Jerry Rice", "Lawrence Taylor", "Jim Brown", "Peyton Manning", "Walter Payton", "Joe Montana", "Reggie White", "Don Hutson", "Johnny Unitas", "Ray Lewis", "Anthony Munoz", "Deion Sanders", "Dan Marino", "Barry Sanders", "Bruce Smith", "Brett Favre", "Dick Butkus", "Aaron Rodgers", "Emmitt Smith", "John Elway", "Ronnie Lott", "Drew Brees", "Calvin Johnson", "Randy Moss", "Ed Reed" ];
        const F1_LEGENDS_DATA = [ "Ayrton Senna", "Michael Schumacher", "Alain Prost", "Niki Lauda", "Juan Manuel Fangio", "Jackie Stewart", "Jim Clark", "Lewis Hamilton", "Sebastian Vettel", "Fernando Alonso", "Nelson Piquet", "Nigel Mansell", "Mika Hakkinen", "Emerson Fittipaldi", "Graham Hill", "Kimi Raikkonen", "Jochen Rindt", "Gilles Villeneuve", "Mario Andretti", "Max Verstappen", "Jenson Button" ];

        const SPORTS = [
          { id: 'Soccer', name: 'FOOTBALL', icon: '⚽', filterSport: 'Soccer', modes: [{ label: 'ALL POSITIONS', val: 'All' }, { label: 'ONLY FORWARDS', val: 'Forward' }, { label: 'ONLY MIDFIELDERS', val: 'Midfield' }, { label: 'ONLY DEFENDERS', val: 'Defend' }, { label: 'ONLY GOALKEEPERS', val: 'Goalkeeper' }] },
          { id: 'Basketball', name: 'NBA', icon: '🏀', filterSport: 'Basketball', directLeague: 'NBA', modes: [{ label: 'ALL POSITIONS', val: 'All' }, { label: 'ONLY GUARDS', val: 'Guard' }, { label: 'ONLY FORWARDS', val: 'Forward' }, { label: 'ONLY CENTERS', val: 'Center' }] },
          { id: 'American Football', name: 'NFL', icon: '🏈', filterSport: 'American Football', directLeague: 'NFL', modes: [{ label: 'ALL POSITIONS', val: 'All' }, { label: 'QUARTERBACKS', val: 'Quarterback' }, { label: 'WIDE RECEIVERS', val: 'Wide Receiver' }, { label: 'RUNNING BACKS', val: 'Running Back' }, { label: 'DEFENSE', val: 'Defense' }] },
          { id: 'Motorsport', name: 'FORMULA 1', icon: '🏎️', filterSport: 'Motorsport', isDirectModes: true, modes: [{ label: 'CURRENT DRIVERS', val: 'Current' }, { label: 'ALL-TIME LEGENDS', val: 'Legends' }] }
        ];

        const fmt = ms => `${Math.floor(ms / 1000)}.${Math.floor((ms % 1000) / 100)}s`;

        const matchPosition = (playerPos, modeVal) => {
          if (!playerPos) return false;
          const p = playerPos.toLowerCase(), f = modeVal.toLowerCase();
          if (f === 'all' || f === 'current' || f === 'legends') return true;
          if (f === 'forward') return p.includes('forward') || p.includes('wing') || p.includes('striker') || p.includes('attack');
          if (f === 'midfield') return p.includes('midfield') || p.includes('wing');
          if (f === 'defend') return p.includes('defend') || p.includes('back');
          if (f === 'goalkeeper') return p.includes('goalkeeper') || p.includes('keeper');
          if (f === 'guard') return p.includes('guard');
          if (f === 'center') return p.includes('center');
          if (f === 'quarterback') return p.includes('quarterback') || p.includes('qb');
          if (f === 'running back') return p.includes('running back') || p.includes('rb');
          if (f === 'wide receiver') return p.includes('wide receiver') || p.includes('wr');
          if (f === 'defense') return p.includes('defens') || p.includes('linebacker') || p.includes('corner') || p.includes('safety') || p.includes('lb') || p.includes('cb') || p.includes('de') || p.includes('dt');
          return p.includes(f);
        };

        const getSupportedMimeType = () => {
            const types = ['video/mp4', 'video/webm;codecs=vp8,opus', 'video/webm;codecs=vp8', 'video/webm;codecs=vp9', 'video/webm'];
            for (let t of types) if (MediaRecorder.isTypeSupported(t)) return t;
            return '';
        };

        function App() {
          const [phase, setPhase] = useState('menu'); 
          const [navStack, setNavStack] = useState(['domain']); 
          const [selection, setSelection] = useState({ domain: null, sport: null, league: null, team: null, mode: null, movieCat: null, actor: null });
          const [leagues, setLeagues] = useState([]);
          const [teams, setTeams] = useState([]);
          
          const [loading, setLoading] = useState(false);
          const [error, setError] = useState(null);
          
          const [slots, setSlots] = useState(Array(10).fill(null));
          const [queue, setQueue] = useState([]);
          const [cur, setCur] = useState(null);
          const [rolling, setRolling] = useState(false);
          const [ms, setMs] = useState(0);
          const [flashSlot, setFlashSlot] = useState(null);
          const [challengeTitle, setChallengeTitle] = useState("BLIND RANK");

          const [cardPos, setCardPos] = useState({ x: 50, y: 25, rotation: 0, scale: 1 });
          const [faceDetected, setFaceDetected] = useState(false);
          
          const [recordStatus, setRecordStatus] = useState('idle'); 
          const [recordedVideoUrl, setRecordedVideoUrl] = useState(null);

          const videoRef = useRef(null);
          const canvasRef = useRef(null);
          const mediaRecorderRef = useRef(null);
          const chunksRef = useRef([]);
          const tickRef = useRef(null);
          const landmarkerRef = useRef(null);
          const prevPos = useRef({ x: 50, y: 25, rotation: 0 });
          const isRecordingRef = useRef(false);
          const renderFrameRef = useRef(null);

          // Active theme logic
          const currentNav = navStack[navStack.length - 1];
          let activeTheme = THEME.sports;
          if (selection.domain === 'movies' || currentNav === 'movies' || currentNav === 'actors') activeTheme = THEME.movies;
          if (selection.domain === 'tv' || currentNav === 'tv') activeTheme = THEME.tv;

          useEffect(() => {
            let active = true;
            
            async function startMedia() {
              try {
                if (navigator.mediaDevices && navigator.mediaDevices.getUserMedia) {
                  const stream = await navigator.mediaDevices.getUserMedia({ video: { facingMode: 'user', width: { ideal: 1280 }, height: { ideal: 720 } }, audio: false });
                  if (active && videoRef.current) {
                      videoRef.current.srcObject = stream;
                      videoRef.current.play().catch(e => console.warn("Auto-play prevented", e));
                  }
                }
              } catch (err) { console.error("Camera access denied."); }

              try {
                const script = document.createElement('script');
                script.src = "https://cdn.jsdelivr.net/npm/@mediapipe/tasks-vision@0.10.3";
                script.async = true;
                document.head.appendChild(script);
                script.onload = async () => {
                  try {
                    const vision = window.tasksVision;
                    if (!vision) return;
                    const resolver = await vision.FilesetResolver.forVisionTasks("https://cdn.jsdelivr.net/npm/@mediapipe/tasks-vision@0.10.3/wasm");
                    landmarkerRef.current = await vision.FaceLandmarker.createFromOptions(resolver, {
                      baseOptions: { modelAssetPath: `https://storage.googleapis.com/mediapipe-models/face_landmarker/face_landmarker/float16/1/face_landmarker.task`, delegate: "GPU" },
                      runningMode: "VIDEO", numFaces: 1
                    });
                    if (active) requestAnimationFrame(predictLoop);
                  } catch (e) {}
                };
              } catch (e) {}
            }

            // ── The Robust Rendering Loop with Images for Export ──
            const drawCanvasRecord = () => {
               if (!isRecordingRef.current || !canvasRef.current || !videoRef.current || videoRef.current.readyState < 2) return;
               const cvs = canvasRef.current;
               const video = videoRef.current;
               
               if (cvs.width !== video.videoWidth || cvs.width === 0) {
                  cvs.width = video.videoWidth || 720;
                  cvs.height = video.videoHeight || 1280;
               }

               const ctx = cvs.getContext('2d');
               const w = cvs.width;
               const h = cvs.height;

               // Base Video Feed
               ctx.save();
               ctx.translate(w, 0); ctx.scale(-1, 1);
               ctx.drawImage(video, 0, 0, w, h);
               ctx.restore();

               // Sidebar Slots with Images
               const slotH = h * 0.065;
               const slotW = w * 0.28; 
               const startX = w * 0.04;

               slots.forEach((p, i) => {
                  const slotY = h * 0.15 + (i * (h * 0.075)); 
                  
                  // 1. Draw Pill Background
                  ctx.fillStyle = p ? activeTheme.primary : 'rgba(0,0,0,0.6)';
                  ctx.beginPath(); ctx.roundRect(startX, slotY, slotW, slotH, slotH / 2);
                  if (p) { ctx.shadowColor = 'rgba(0,0,0,0.5)'; ctx.shadowBlur = 12; ctx.shadowOffsetY = 4; }
                  ctx.fill(); ctx.shadowColor = 'transparent';

                  // 2. Draw Rank Number
                  ctx.fillStyle = p ? '#000' : '#fff';
                  ctx.font = `bold ${Math.round(h*0.025)}px sans-serif`;
                  ctx.textAlign = 'center';
                  ctx.fillText(i + 1, startX + (slotW * 0.35), slotY + (slotH/2) + (h*0.008));

                  if (p) {
                      // 3. Draw Small Image Thumbnail inside the pill
                      if (p.imgObj && p.imgObj.complete) {
                          ctx.save();
                          ctx.beginPath();
                          const imgSize = slotH - 6;
                          const imgX = startX + slotW - imgSize - 3;
                          const imgY = slotY + 3;
                          ctx.arc(imgX + imgSize/2, imgY + imgSize/2, imgSize/2, 0, Math.PI * 2);
                          ctx.clip();
                          ctx.drawImage(p.imgObj, imgX, imgY, imgSize, imgSize);
                          ctx.restore();
                      }
                      
                      // 4. Draw Movie/Player Name text outside the pill
                      ctx.fillStyle = '#fff';
                      ctx.font = `bold ${Math.round(h*0.028)}px sans-serif`;
                      ctx.textAlign = 'left';
                      ctx.shadowColor = "rgba(0,0,0,0.9)";
                      ctx.shadowBlur = 6;
                      ctx.fillText(p.name.substring(0, 18) + (p.name.length > 18 ? '...' : ''), startX + slotW + 16, slotY + (slotH/2) + (h*0.008));
                      ctx.shadowColor = 'transparent';
                  }
               });

               // Main Floating Card
               if (cur && faceDetected) {
                   const cx = (cardPos.x / 100) * w; const cy = (cardPos.y / 100) * h;
                   const scale = cardPos.scale * 1.5; const boxW = 160 * scale; const boxH = 160 * scale;

                   ctx.save();
                   ctx.translate(cx, cy); ctx.rotate((cardPos.rotation * Math.PI) / 180);
                   ctx.translate(-boxW/2, -boxH - (h * 0.05));

                   // Glow Border
                   ctx.fillStyle = activeTheme.primary;
                   ctx.beginPath(); ctx.roundRect(0, 0, boxW, boxH, 20);
                   ctx.shadowColor = activeTheme.primary; ctx.shadowBlur = 25; ctx.fill(); ctx.shadowColor = 'transparent';

                   // Draw Poster / Player Photo
                   if (cur.imgObj && cur.imgObj.complete) {
                       ctx.save();
                       ctx.beginPath(); ctx.roundRect(6, 6, boxW - 12, boxH - 12, 16); ctx.clip();
                       if (cur.isRolling) ctx.globalAlpha = 0.5;
                       ctx.drawImage(cur.imgObj, 6, 6, boxW - 12, boxH - 12);
                       ctx.restore();
                   } else {
                       ctx.fillStyle = '#000';
                       ctx.beginPath(); ctx.roundRect(6, 6, boxW - 12, boxH - 12, 16); ctx.fill();
                   }
                   
                   // Name Badge Below Card
                   ctx.fillStyle = activeTheme.primary;
                   ctx.beginPath(); ctx.roundRect(-20, boxH + 15, boxW + 40, 40 * scale, 20 * scale); ctx.fill();

                   ctx.fillStyle = '#000';
                   ctx.font = `bold ${18 * scale}px sans-serif`;
                   ctx.textAlign = 'center';
                   ctx.fillText(cur.name.substring(0, 18), boxW/2, boxH + 15 + (26 * scale));
                   ctx.restore();
               }

               // Category Badge at bottom of video
               ctx.fillStyle = 'rgba(0,0,0,0.85)';
               ctx.beginPath(); ctx.roundRect(w/2 - 160, h - (h * 0.08), 320, 45, 22); ctx.fill();
               ctx.fillStyle = activeTheme.primary;
               ctx.font = 'bold 16px sans-serif';
               ctx.textAlign = 'center';
               ctx.fillText("🏆 " + challengeTitle.toUpperCase(), w/2, h - (h * 0.08) + 28);
            };

            const renderLoop = () => {
                if (!active) return;
                if (isRecordingRef.current) drawCanvasRecord();
                renderFrameRef.current = requestAnimationFrame(renderLoop);
            };

            const predictLoop = () => {
              if (!active) return;
              if (videoRef.current && landmarkerRef.current) {
                try {
                  const results = landmarkerRef.current.detectForVideo(videoRef.current, performance.now());
                  if (results.faceLandmarks?.[0]) {
                    setFaceDetected(true);
                    const l = results.faceLandmarks[0];
                    const forehead = l[151], le = l[33], re = l[263];
                    const angle = Math.atan2(re.y - le.y, re.x - le.x) * (180 / Math.PI);
                    const fw = Math.sqrt(Math.pow(re.x - le.x, 2) + Math.pow(re.y - le.y, 2));
                    const tx = (1 - forehead.x) * 100, ty = forehead.y * 100;
                    const lerp = (s, e, a) => s + (e - s) * a;
                    const nx = lerp(prevPos.current.x, tx, 0.22), ny = lerp(prevPos.current.y, ty, 0.22), nr = lerp(prevPos.current.rotation, angle, 0.22);
                    prevPos.current = { x: nx, y: ny, rotation: nr };
                    setCardPos({ x: nx, y: ny, rotation: nr, scale: Math.max(0.7, fw * 7.5) });
                  } else { setFaceDetected(false); }
                } catch (e) {}
              }
              requestAnimationFrame(predictLoop);
            };

            startMedia();
            renderFrameRef.current = requestAnimationFrame(renderLoop);
            return () => { active = false; clearInterval(tickRef.current); cancelAnimationFrame(renderFrameRef.current); };
          }, [selection.domain, cur, slots, challengeTitle, activeTheme.primary]);

          // ── BULLETPROOF RECORDING INITIALIZATION ──
          const startRecording = () => {
            if (recordStatus !== 'idle' && recordStatus !== 'error') return;
            try {
              chunksRef.current = [];
              const cvs = canvasRef.current;
              const video = videoRef.current;
              
              if (!cvs || !cvs.captureStream || !video) { setRecordStatus('error'); return; }

              if (video.videoWidth) {
                  cvs.width = video.videoWidth; cvs.height = video.videoHeight;
              } else {
                  cvs.width = 720; cvs.height = 1280;
              }

              const ctx = cvs.getContext('2d');
              ctx.fillStyle = '#000'; ctx.fillRect(0, 0, cvs.width, cvs.height);
              ctx.drawImage(video, 0, 0, cvs.width, cvs.height);

              const stream = cvs.captureStream(30); 

              let options = {}; 
              if (MediaRecorder.isTypeSupported('video/mp4')) {
                  options = { mimeType: 'video/mp4' };
              } else if (MediaRecorder.isTypeSupported('video/webm;codecs=vp8')) {
                  options = { mimeType: 'video/webm;codecs=vp8' };
              } else if (MediaRecorder.isTypeSupported('video/webm')) {
                  options = { mimeType: 'video/webm' };
              }
              
              mediaRecorderRef.current = new MediaRecorder(stream, options);
              mediaRecorderRef.current.ondataavailable = e => {
                 if(e.data && e.data.size > 0) chunksRef.current.push(e.data);
              };
              
              mediaRecorderRef.current.onstop = () => {
                 if (chunksRef.current.length === 0) {
                     setRecordStatus('error'); return;
                 }
                 const finalMime = mediaRecorderRef.current.mimeType || options.mimeType || 'video/mp4';
                 const blob = new Blob(chunksRef.current, { type: finalMime });
                 const url = URL.createObjectURL(blob);
                 setRecordedVideoUrl({ url, ext: finalMime.includes('webm') ? 'webm' : 'mp4' });
                 setRecordStatus('ready'); 
              };
              
              mediaRecorderRef.current.start(); 
              isRecordingRef.current = true;
              setRecordStatus('recording');
            } catch (e) { 
              console.error(e);
              setRecordStatus('error');
            }
          };

          const stopRecordingAndCompile = () => {
            if (mediaRecorderRef.current && mediaRecorderRef.current.state !== 'inactive') {
              setRecordStatus('compiling'); 
              
              if (canvasRef.current && videoRef.current) {
                  const ctx = canvasRef.current.getContext('2d');
                  ctx.drawImage(videoRef.current, 0, 0, canvasRef.current.width, canvasRef.current.height);
              }
              
              setTimeout(() => {
                  if (mediaRecorderRef.current.state !== 'inactive') {
                      try { mediaRecorderRef.current.requestData(); } catch (e) {}
                      mediaRecorderRef.current.stop();
                  }
              }, 150); 
            } else {
               if (chunksRef.current.length > 0) setRecordStatus('ready'); else setRecordStatus('error');
            }
            isRecordingRef.current = false;
          };

          const fetchSportsDB = async (endpoint) => { try { const res = await fetch(`https://www.thesportsdb.com/api/v1/json/3/${endpoint}`); return res.ok ? await res.json() : null; } catch (e) { return null; } };
          const fetchTMDB = async (endpoint, page = 1) => { try { const sep = endpoint.includes('?') ? '&' : '?'; const res = await fetch(`https://api.themoviedb.org/3${endpoint}${sep}api_key=${TMDB_KEY}&language=en-US&page=${page}`); return res.ok ? await res.json() : null; } catch (e) { return null; } };

          const pickDomain = (domain) => { setSelection({ domain, sport: null, league: null, team: null, mode: null, movieCat: null, actor: null }); setNavStack([domain]); };

          const selectSport = async (sport) => {
            if (sport.isDirectModes) { setSelection(p => ({ ...p, sport, league: null, team: null })); setNavStack([...navStack, 'modes']); return; }
            if (sport.directLeague) {
              setLoading(true); const data = await fetchSportsDB(`search_all_teams.php?l=${encodeURIComponent(sport.directLeague)}`);
              if (data?.teams) { setTeams(data.teams); setSelection(p => ({ ...p, sport, league: { strLeague: sport.directLeague }, team: null })); setNavStack(['sports', 'teams']); } 
              else { setError(`Could not load ${sport.name} teams.`); }
              setLoading(false); return;
            }
            setLeagues([ { idLeague: '4328', strLeague: 'English Premier League' }, { idLeague: '4335', strLeague: 'Spanish La Liga' }, { idLeague: '4331', strLeague: 'German Bundesliga' }, { idLeague: '4332', strLeague: 'Italian Serie A' }, { idLeague: '4334', strLeague: 'French Ligue 1' }, { idLeague: '4346', strLeague: 'American Major League Soccer' }, { idLeague: '4337', strLeague: 'Dutch Eredivisie' } ]);
            setSelection(p => ({ ...p, sport, league: null, team: null })); setNavStack(['sports', 'leagues']);
          };

          const selectLeague = async (league) => {
            setLoading(true); const data = await fetchSportsDB(`search_all_teams.php?l=${encodeURIComponent(league.strLeague)}`);
            if (data?.teams) { setTeams(data.teams); setSelection(p => ({ ...p, league })); setNavStack(['sports', 'leagues', 'teams']); } 
            else { setError("Could not load teams."); } setLoading(false);
          };

          const selectTeam = (team) => { setSelection(p => ({ ...p, team })); setNavStack([...navStack, 'modes']); };

          // ── PRELOADING IMAGES FOR CANVAS (CRITICAL FIX FOR CORS) ──
          const processSessionAndLaunch = (session) => {
             // Create real HTMLImageElements with CrossOrigin permission so Canvas can record them safely
             const sessionWithImages = session.map(item => {
                const imgObj = new Image();
                imgObj.crossOrigin = "anonymous"; 
                imgObj.src = item.img;
                return { ...item, imgObj };
             });
             
             setSlots(Array(10).fill(null)); 
             setQueue(sessionWithImages);
             setRecordStatus('idle'); setRecordedVideoUrl(null); isRecordingRef.current = false;
             setPhase('playing');
             const startMs = Date.now(); tickRef.current = setInterval(() => setMs(Date.now() - startMs), 100);
             doRoll(sessionWithImages);
          };

          const startActorChallenge = async (actorName) => {
            setLoading(true); setError(null); setSelection(p => ({ ...p, actor: actorName }));
            try {
              const searchRes = await fetchTMDB(`/search/person?query=${encodeURIComponent(actorName)}`);
              if (!searchRes?.results?.length) { throw new Error(); }
              const creditsRes = await fetchTMDB(`/person/${searchRes.results[0].id}/movie_credits`);
              if (!creditsRes?.cast) { throw new Error(); }
              const movies = creditsRes.cast.filter(m => m.poster_path && m.title).sort((a, b) => b.popularity - a.popularity);
              const unique = Array.from(new Map(movies.map(m => [m.id, { id: m.id, name: m.title, img: `https://image.tmdb.org/t/p/w500${m.poster_path}` }])).values());
              if (unique.length < 10) { setError(`${actorName} has too few movies.`); setLoading(false); return; }
              const topMovies = unique.slice(0, 30).sort(() => Math.random() - 0.5).slice(0, 10);
              setChallengeTitle(actorName.toUpperCase()); processSessionAndLaunch(topMovies);
            } catch (e) { setError(`Failed to load ${actorName}.`); setLoading(false); }
          };

          const startTMDBChallenge = async (cat, type = 'movie') => {
            setLoading(true); setError(null); setSelection(p => ({ ...p, movieCat: cat }));
            try {
              const randomPage1 = Math.floor(Math.random() * 5) + 1; let randomPage2 = Math.floor(Math.random() * 5) + 1; if (randomPage1 === randomPage2) randomPage2 = (randomPage2 % 5) + 1;
              const results = await Promise.all([ fetchTMDB(cat.endpoint, randomPage1), fetchTMDB(cat.endpoint, randomPage2) ]);
              const allMedia = results.flatMap(r => r?.results || []);
              const finalPool = allMedia.filter(m => m.poster_path && (m.title || m.name)).filter(m => { if (cat.id === 'animation') return true; return m.genre_ids && !m.genre_ids.includes(16); })
                .map(m => ({ id: m.id, name: m.title || m.name, img: `https://image.tmdb.org/t/p/w500${m.poster_path}` }));
              const unique = Array.from(new Map(finalPool.map(item => [item.id, item])).values());
              const sessionMedia = unique.sort(() => Math.random() - 0.5).slice(0, 10);
              if (sessionMedia.length < 10) { setError("Not enough data found."); setLoading(false); return; }
              setChallengeTitle(cat.name); processSessionAndLaunch(sessionMedia);
            } catch (e) { setError("Error syncing with Database."); setLoading(false); }
          };

          const startSportsChallenge = async (mode) => {
            setLoading(true); setError(null); setSelection(p => ({ ...p, mode }));
            let targetSport = selection.sport.filterSport;
            try {
              let rawPlayers = [];
              if (selection.team?.isLegends || mode.val === 'Legends') {
                 let arr = SOCCER_LEGENDS_DATA;
                 if (selection.sport.id === 'Basketball') arr = NBA_LEGENDS_DATA;
                 if (selection.sport.id === 'American Football') arr = NFL_LEGENDS_DATA;
                 if (selection.sport.id === 'Motorsport') arr = F1_LEGENDS_DATA;
                 const shuffled = [...arr].sort(() => Math.random() - 0.5).slice(0, 25);
                 const results = await Promise.all(shuffled.map(n => fetchSportsDB(`searchplayers.php?p=${encodeURIComponent(n)}`)));
                 rawPlayers = results.flatMap(r => r?.player || []);
                 setChallengeTitle(selection.team?.strTeam || selection.sport.name + ' LEGENDS');
              } else if (selection.sport.id === 'Motorsport' && mode.val === 'Current') {
                 const teamsData = await fetchSportsDB(`search_all_teams.php?l=Formula%201`);
                 if (teamsData?.teams) {
                     const rosters = await Promise.all(teamsData.teams.map(t => fetchSportsDB(`lookup_all_players.php?id=${t.idTeam}`)));
                     rawPlayers = rosters.flatMap(r => r?.player || []).filter(p => p.strPosition?.toLowerCase().includes('driver'));
                 }
                 setChallengeTitle('F1 CURRENT GRID');
              } else if (selection.team && !selection.team.isLegends) {
                const d = await fetchSportsDB(`lookup_all_players.php?id=${selection.team.idTeam}`); rawPlayers = d?.player || []; setChallengeTitle(selection.team.strTeam);
              } else {
                const teamsSample = [...teams].sort(() => Math.random() - 0.5).slice(0, 15);
                const rosters = await Promise.all(teamsSample.map(t => fetchSportsDB(`lookup_all_players.php?id=${t.idTeam}`)));
                rawPlayers = rosters.flatMap(r => r?.player || []); setChallengeTitle(selection.league?.strLeague || selection.sport.name);
              }

              const cleanPlayers = rawPlayers.filter(p => {
                 if (!p || !p.strPlayer) return false;
                 if (targetSport === 'Motorsport') return p.strPosition?.toLowerCase().includes('driver'); 
                 if (p.strSport) return p.strSport.toLowerCase() === targetSport.toLowerCase();
                 return !!selection.team;
              });

              const poolItems = cleanPlayers.map(p => ({ id: p.idPlayer || Math.random(), name: p.strPlayer, img: p.strCutout || p.strRender || p.strThumb, pos: p.strPosition, teamId: p.idTeam }))
                .filter(p => matchPosition(p.pos, mode.val) && p.img);

              let unique = Array.from(new Map(poolItems.map(item => [item.name, item])).values());
              let sessionPlayers = [];

              if (!selection.team && !mode.val.includes('Legends') && selection.sport.id !== 'Motorsport') {
                 const byTeam = {}; unique.forEach(p => { const tId = p.teamId || 'unknown'; if (!byTeam[tId]) byTeam[tId] = []; byTeam[tId].push(p); });
                 Object.values(byTeam).forEach(arr => arr.sort(() => Math.random() - 0.5)); const teamKeys = Object.keys(byTeam).sort(() => Math.random() - 0.5);
                 const diversePool = []; while (diversePool.length < unique.length) { let added = false; for (const tk of teamKeys) { if (byTeam[tk].length > 0) { diversePool.push(byTeam[tk].pop()); added = true; } } if (!added) break; }
                 sessionPlayers = diversePool.slice(0, 10).sort(() => Math.random() - 0.5);
              } else { sessionPlayers = unique.sort(() => Math.random() - 0.5).slice(0, 10); }
              
              if (sessionPlayers.length < 10) { setError(`Not enough players found.`); setLoading(false); return; }
              processSessionAndLaunch(sessionPlayers);
            } catch (e) { setError("Database sync error."); setLoading(false); }
          };

          const doRoll = useCallback((pool) => {
            if (!pool.length) return;
            setRolling(true); let ticks = 0;
            const iv = setInterval(() => {
              setCur({ ...pool[Math.floor(Math.random() * pool.length)], isRolling: true });
              if (++ticks >= 15) { clearInterval(iv); setCur(pool[0]); setRolling(false); }
            }, 60);
          }, []);

          const place = (i) => {
            if (slots[i] || !cur || rolling) return;
            const n = [...slots]; n[i] = cur;
            setSlots(n); setFlashSlot(i); setTimeout(() => setFlashSlot(null), 300);
            const nq = queue.slice(1); setQueue(nq);
            if (nq.length === 0) { clearInterval(tickRef.current); setTimeout(() => { setPhase('result'); }, 600); } else { doRoll(nq); }
          };

          const back = () => {
            setError(null);
            if (isRecordingRef.current) { chunksRef.current = []; stopRecordingAndCompile(); }
            if (navStack.length > 1) { if (navStack[navStack.length - 1] === 'teams' && selection.sport?.directLeague) { setNavStack(['sports']); } else { setNavStack(p => p.slice(0, -1)); } } 
            else setNavStack(['domain']);
          };

          return (
            <div className={`relative w-full h-[100dvh] bg-[#030305] overflow-hidden body-font select-none text-white antialiased`}>
              
              {/* THE CAMERA FEED IS NOW 100% VISIBLE */}
              <video ref={videoRef} autoPlay playsInline muted className="absolute inset-0 w-full h-full object-cover scale-x-[-1] z-0 opacity-100" />
              
              {/* VIBRANT AMBIENT TINT: Uses mix-blend-screen so your face stays bright and clear! */}
              <div className={`absolute inset-0 z-10 opacity-40 mix-blend-screen ${activeTheme.bg} transition-colors duration-1000 pointer-events-none`} />
              <div className="absolute inset-0 bg-gradient-to-b from-[#030305]/10 via-[#030305]/40 to-[#030305]/95 z-10 pointer-events-none" />
              
              {/* THE CANVAS FIX: 1x1 hidden div. Browser strictly renders this natively without blocking the UI or the camera! */}
              <div className="absolute top-0 left-0 w-[1px] h-[1px] overflow-hidden opacity-100 pointer-events-none z-0">
                  <canvas ref={canvasRef} />
              </div>

              {/* ── Top HUD (Safe Area Included) ── */}
              {phase === 'playing' && (
                <div className="absolute top-[env(safe-area-inset-top,2rem)] inset-x-4 sm:inset-x-6 flex justify-between items-start z-50 pointer-events-auto pt-4">
                  
                  <div className="flex flex-col gap-2">
                      {recordStatus === 'idle' || recordStatus === 'error' ? (
                        <button onClick={startRecording} className="glass-premium px-4 py-3 rounded-[16px] flex items-center gap-2.5 transition-all active:scale-95 border-white/20 hover:bg-white/10 shadow-lg">
                          <div className="w-3 h-3 rounded-full bg-[#FF3D5A] shadow-[0_0_12px_#FF3D5A]" />
                          <span className="display-font text-[12px] font-black tracking-widest text-white">START RECORD</span>
                        </button>
                      ) : (
                        <div className="bg-red-500/20 border border-red-500/50 px-4 py-3 rounded-[16px] flex items-center gap-2.5 backdrop-blur-md shadow-[0_0_25px_rgba(255,61,90,0.4)]">
                          <div className="w-3 h-3 rounded-full bg-[#FF3D5A] animate-pulse" />
                          <span className="display-font text-[12px] font-black tracking-widest text-white">RECORDING</span>
                        </div>
                      )}
                      
                      {recordStatus === 'error' && (
                         <div className="text-[#FF3D5A] text-[10px] font-bold tracking-widest bg-black/80 backdrop-blur-md px-3 py-1.5 rounded-lg border border-[#FF3D5A]/40 shadow-lg">BLOCKED BY BROWSER</div>
                      )}
                  </div>

                  <div className="glass-premium px-5 py-3 rounded-[16px] border-white/20 shadow-lg bg-[#030305]/80">
                    <span className={`display-font font-black text-sm tracking-widest`} style={{ color: activeTheme.primary }}>{fmt(ms)}</span>
                  </div>
                </div>
              )}

              {/* ── Premium Menu ── */}
              {phase === 'menu' && (
                <div className="absolute inset-0 z-50 flex flex-col items-center justify-center px-5 sm:px-8 glass-panel pt-safe pb-safe">
                  <div className="w-full max-w-sm flex flex-col h-full py-6">
                    <div className="flex items-center justify-between mb-8 shrink-0">
                      {currentNav !== 'domain' ? (
                        <button onClick={back} className="w-12 h-12 rounded-full glass-premium border-white/20 hover:bg-white/10 flex items-center justify-center active:scale-95 transition-all shadow-lg">
                          <ArrowLeft size={20} />
                        </button>
                      ) : <div className="w-12" />}
                      <h1 className={`display-font text-xl font-black tracking-[0.15em] uppercase text-center`} style={{ color: activeTheme.primary, textShadow: `0 0 25px ${activeTheme.primary}50` }}>
                        {currentNav === 'domain' ? 'SELECT CATEGORY' : currentNav === 'actors' ? 'HOLLYWOOD ICONS' : currentNav === 'modes' ? 'CHALLENGE MODES' : currentNav}
                      </h1>
                      <div className="w-12" />
                    </div>

                    {error && (
                      <div className="mb-6 p-4 bg-red-500/10 border border-red-500/40 rounded-[16px] flex items-start gap-3 text-red-50 anim-pop shadow-lg backdrop-blur-md">
                        <AlertCircle size={20} className="shrink-0 mt-0.5 text-red-400" />
                        <span className="text-[13px] font-semibold leading-tight tracking-wide">{error}</span>
                      </div>
                    )}

                    <div className="flex-1 overflow-y-auto no-scrollbar space-y-4 pb-10">
                      {loading ? (
                        <div className="h-64 flex flex-col items-center justify-center gap-6">
                          <Loader2 className={`animate-spin`} style={{ color: activeTheme.primary }} size={50} />
                          <span className="display-font text-[12px] font-black uppercase tracking-[0.3em] opacity-80" style={{ color: activeTheme.primary }}>Syncing Database</span>
                        </div>
                      ) : (
                        <>
                          {currentNav === 'domain' && (
                            <div className="flex flex-col gap-5 mt-4">
                              <button onClick={() => pickDomain('sports')} className="w-full flex flex-col items-center justify-center p-10 rounded-[32px] active:scale-[0.97] transition-all bg-gradient-to-br from-[#00D4FF]/10 to-[#0066FF]/20 border border-[#00D4FF]/40 hover:border-[#00D4FF] shadow-[0_15px_40px_rgba(0,102,255,0.15)] group">
                                <TrophyIcon size={56} className="text-[#00D4FF] mb-4 group-hover:scale-110 transition-transform drop-shadow-[0_0_20px_rgba(0,212,255,0.6)]" />
                                <span className="display-font font-black text-2xl tracking-[0.25em] text-white">SPORTS</span>
                                <span className="body-font text-[10px] text-[#00D4FF] mt-2 font-bold tracking-[0.2em]">FOOTBALL, NBA, F1, NFL</span>
                              </button>
                              
                              <button onClick={() => pickDomain('movies')} className="w-full flex flex-col items-center justify-center p-10 rounded-[32px] active:scale-[0.97] transition-all bg-gradient-to-br from-[#FFB800]/10 to-[#FF3D5A]/20 border border-[#FFB800]/40 hover:border-[#FFB800] shadow-[0_15px_40px_rgba(255,61,90,0.15)] group">
                                <PopcornIcon size={56} className="text-[#FFB800] mb-4 group-hover:scale-110 transition-transform drop-shadow-[0_0_20px_rgba(255,184,0,0.6)]" />
                                <span className="display-font font-black text-2xl tracking-[0.25em] text-white">MOVIES</span>
                                <span className="body-font text-[10px] text-[#FFB800] mt-2 font-bold tracking-[0.2em]">POWERED BY TMDB</span>
                              </button>
                              
                              <button onClick={() => pickDomain('tv')} className="w-full flex flex-col items-center justify-center p-10 rounded-[32px] active:scale-[0.97] transition-all bg-gradient-to-br from-[#D946EF]/10 to-[#7C3AED]/20 border border-[#D946EF]/40 hover:border-[#D946EF] shadow-[0_15px_40px_rgba(124,58,237,0.15)] group">
                                <TvIcon size={56} className="text-[#D946EF] mb-4 group-hover:scale-110 transition-transform drop-shadow-[0_0_20px_rgba(217,70,239,0.6)]" />
                                <span className="display-font font-black text-2xl tracking-[0.25em] text-white">TV SHOWS</span>
                                <span className="body-font text-[10px] text-[#D946EF] mt-2 font-bold tracking-[0.2em]">THE GREATEST SERIES</span>
                              </button>
                            </div>
                          )}

                          {currentNav === 'movies' && MOVIE_CATS.map((c, i) => (
                            <button key={c.id} onClick={() => { if (c.isActorMode) setNavStack([...navStack, 'actors']); else startTMDBChallenge(c, 'movie'); }} 
                              className={`w-full flex items-center justify-between glass-premium p-5 rounded-[24px] active:scale-[0.98] transition-all hover:bg-white/10 ${i === 0 ? 'border-[#FFB800]/50 bg-gradient-to-r from-[#FFB800]/10 to-transparent shadow-[0_8px_30px_rgba(255,184,0,0.2)]' : 'border-white/15'}`}>
                              <div className="flex items-center gap-5">
                                <span className="text-3xl drop-shadow-md">{c.icon}</span>
                                <div className="flex flex-col items-start text-left">
                                  <span className="display-font font-black text-[15px] tracking-widest text-white">{c.name}</span>
                                  {c.isActorMode && <span className="body-font text-[10px] font-bold text-[#FFB800] tracking-widest mt-1">50 TOP ACTORS</span>}
                                </div>
                              </div>
                              <ChevronRight size={20} className="text-[#FFB800]" />
                            </button>
                          ))}

                          {currentNav === 'tv' && TV_CATS.map((c, i) => (
                            <button key={c.id} onClick={() => startTMDBChallenge(c, 'tv')} 
                              className={`w-full flex items-center justify-between glass-premium p-5 rounded-[24px] active:scale-[0.98] transition-all hover:bg-white/10 border-white/15`}>
                              <div className="flex items-center gap-5">
                                <span className="text-3xl drop-shadow-md">{c.icon}</span>
                                <div className="flex flex-col items-start text-left">
                                  <span className="display-font font-black text-[15px] tracking-widest text-white">{c.name}</span>
                                </div>
                              </div>
                              <ChevronRight size={20} className="text-[#D946EF]" />
                            </button>
                          ))}

                          {currentNav === 'actors' && (
                            <div className="grid grid-cols-1 gap-3 pb-6">
                              {ACTORS_DATA.map(actor => (
                                <button key={actor} onClick={() => startActorChallenge(actor)} className="w-full flex items-center justify-between glass-premium p-5 rounded-[20px] active:scale-[0.98] transition-all text-left border-white/15 hover:border-[#FFB800]/50 hover:bg-[#FFB800]/5 shadow-sm">
                                  <span className="display-font font-bold text-[14px] tracking-[0.15em] uppercase text-white pl-2">{actor}</span>
                                  <ChevronRight size={18} className="text-[#FFB800]" />
                                </button>
                              ))}
                            </div>
                          )}

                          {currentNav === 'sports' && SPORTS.map((s, i) => (
                            <button key={s.id} onClick={() => selectSport(s)} className={`w-full flex items-center justify-between glass-premium p-5 rounded-[24px] active:scale-[0.98] transition-all hover:bg-white/10 ${s.isDirectModes ? 'border-[#00D4FF]/50 bg-gradient-to-r from-[#00D4FF]/10 to-transparent shadow-[0_8px_30px_rgba(0,212,255,0.2)]' : 'border-white/15'}`}>
                              <div className="flex items-center gap-5">
                                <span className="text-3xl drop-shadow-md">{s.icon}</span>
                                <div className="flex flex-col items-start text-left">
                                  <span className="display-font font-black text-[15px] tracking-widest text-white">{s.name}</span>
                                  {s.isDirectModes && <span className="body-font text-[10px] font-bold text-[#00D4FF] tracking-widest mt-1">NO TEAMS, ALL DRIVERS</span>}
                                </div>
                              </div>
                              <ChevronRight size={20} className="text-[#00D4FF]" />
                            </button>
                          ))}

                          {currentNav === 'leagues' && leagues.map(l => (
                            <button key={l.idLeague} onClick={() => selectLeague(l)} className="w-full flex items-center justify-between glass-premium p-5 rounded-[20px] active:scale-[0.98] transition-all text-left border-white/15 hover:border-[#00D4FF]/50 hover:bg-[#00D4FF]/5 shadow-sm">
                              <span className="display-font font-bold text-[12px] tracking-widest uppercase truncate pr-4 pl-2 text-white">{l.strLeague}</span>
                              <ChevronRight size={18} className="text-[#00D4FF]" />
                            </button>
                          ))}

                          {currentNav === 'teams' && (
                            <>
                              <button onClick={() => selectTeam({ isLegends: true, strTeam: `${selection.sport.name} Legends` })} className="w-full bg-gradient-to-r from-[#FFB800] to-[#FF3D5A] p-5.5 rounded-[24px] active:scale-[0.98] transition-all mb-4 text-[#030305] flex items-center justify-center gap-3 shadow-[0_12px_35px_rgba(255,184,0,0.35)] border-none">
                                <StarIcon size={22} fill="#030305" />
                                <span className="display-font font-black text-[14px] tracking-[0.2em]">ALL-TIME LEGENDS</span>
                              </button>
                              <button onClick={() => selectTeam(null)} className="w-full bg-gradient-to-r from-[#00D4FF] to-[#0066FF] p-5.5 rounded-[24px] active:scale-[0.98] transition-all mb-6 text-white flex items-center justify-center gap-3 shadow-[0_12px_35px_rgba(0,212,255,0.35)] border-none">
                                <UsersIcon size={22} />
                                <span className="display-font font-black text-[14px] tracking-[0.2em]">ALL CURRENT STARS</span>
                              </button>
                              <div className="grid grid-cols-1 gap-3.5">
                                {teams.map(t => (
                                  <button key={t.idTeam} onClick={() => selectTeam(t)} className="w-full flex items-center gap-4 glass-premium p-4 rounded-[20px] active:scale-[0.98] transition-all text-left border-white/15 hover:border-white/40 shadow-sm">
                                    <div className="w-12 h-12 bg-white/10 rounded-full flex items-center justify-center p-2.5 shrink-0 border border-white/20">
                                        <img src={t.strTeamBadge} className="w-full h-full object-contain" alt="" />
                                    </div>
                                    <span className="display-font font-bold text-[13px] tracking-widest uppercase truncate">{t.strTeam}</span>
                                  </button>
                                ))}
                              </div>
                            </>
                          )}

                          {currentNav === 'modes' && (
                            <>
                              <div className="mb-8 p-6 rounded-[24px] border border-white/20 glass-premium text-center shadow-lg">
                                 <span className={`display-font text-[11px] font-black tracking-[0.3em] uppercase block mb-3 drop-shadow-md`} style={{ color: activeTheme.primary }}>Target Roster</span>
                                 <span className="display-font text-[18px] font-black tracking-widest uppercase truncate block text-white drop-shadow-lg">
                                   {selection.team ? selection.team.strTeam : (selection.league ? selection.league.strLeague : selection.sport.name)}
                                 </span>
                              </div>
                              
                              {selection.team?.isLegends ? (
                                <button onClick={() => startSportsChallenge({ val: 'All' })} className={`w-full flex justify-between items-center p-6 rounded-[24px] active:scale-[0.98] transition-all mb-4 border-none`} style={{ background: `linear-gradient(135deg, ${activeTheme.primary}, ${activeTheme.secondary})`, color: '#030305', boxShadow: `0 12px 35px ${activeTheme.primary}60` }}>
                                  <span className={`display-font text-[14px] tracking-widest uppercase font-black`}>ALL ICONS</span>
                                  <UsersIcon size={22} />
                                </button>
                              ) : (
                                selection.sport.modes.map((m, i) => (
                                  <button key={m.val} onClick={() => startSportsChallenge(m)} 
                                    className={`w-full flex justify-between items-center p-6 rounded-[24px] active:scale-[0.98] transition-all mb-4 ${i === 0 ? 'border-none' : 'glass-premium hover:bg-white/15 border-white/20'}`} 
                                    style={i === 0 ? { background: `linear-gradient(135deg, ${activeTheme.primary}, ${activeTheme.secondary})`, color: (selection.domain === 'sports' ? '#fff' : '#030305'), boxShadow: `0 12px 35px ${activeTheme.primary}60` } : {}}>
                                    <span className={`display-font text-[14px] tracking-widest uppercase ${i === 0 ? 'font-black' : 'font-bold text-white'}`}>{m.label}</span>
                                    {i === 0 ? <UsersIcon size={22} /> : <FilterIcon size={22} className="opacity-60 text-white" />}
                                  </button>
                                ))
                              )}
                            </>
                          )}
                        </>
                      )}
                    </div>
                  </div>
                </div>
              )}

              {/* ── PREMIUM PLAYING CARD ── */}
              {phase === 'playing' && cur && (
                <div className="absolute z-40 transition-all duration-75 pointer-events-none origin-bottom" style={{
                  left: `${cardPos.x}%`, top: `${cardPos.y}%`, 
                  transform: `translate(-50%, -100%) rotate(${cardPos.rotation}deg) scale(${cardPos.scale})`,
                  marginTop: '-3%', opacity: (faceDetected || !landmarkerRef.current) ? 1 : 0.4
                }}>
                  <div className="flex flex-col items-center animate-float pb-4">
                     <div className="relative">
                        <div className={`absolute -inset-6 blur-3xl rounded-full opacity-60`} style={{ backgroundColor: activeTheme.primary }} />
                        <div className={`glass-card relative w-44 h-44 rounded-[36px] flex items-center justify-center overflow-hidden border-[6px] shadow-[0_20px_50px_rgba(0,0,0,0.8)]`} style={{ borderColor: activeTheme.primary }}>
                            <div className={`w-full h-full transition-all duration-200 ${rolling ? 'blur-md grayscale scale-[0.9] opacity-40' : 'opacity-100 scale-100'}`}>
                                <div className="absolute inset-0 bg-[#030305] flex flex-col items-center justify-center z-0">
                                  {selection.domain === 'movies' || selection.domain === 'tv' ? <PopcornIcon size={56} className="text-white/10 mb-2" /> : <UserIcon size={56} className="text-white/10 mb-2" />}
                                </div>
                                {cur.img ? ( <img key={cur.id} id="floating-card-img" src={cur.img} className="w-full h-full object-cover relative z-10" alt="" /> ) : null}
                            </div>
                            {rolling && <div className={`absolute inset-0 z-20 animate-scan bg-white/20`} />}
                        </div>
                     </div>
                     <div className={`mt-6 w-[130%] max-w-[200px] px-4 py-4 rounded-[20px] shadow-[0_20px_40px_rgba(0,0,0,0.6)] transition-all duration-300 flex items-center justify-center`} style={{ background: `linear-gradient(145deg, ${activeTheme.primary}, ${activeTheme.secondary})`, opacity: rolling ? 0 : 1, transform: rolling ? 'translateY(15px)' : 'translateY(0)' }}>
                        <span className={`display-font font-black uppercase tracking-tight text-center line-clamp-3 leading-tight ${selection.domain === 'movies' || selection.domain === 'tv' ? 'text-[13px] text-[#030305]' : 'text-[14px] text-white'}`}>
                          {cur.name}
                        </span>
                     </div>
                  </div>
                </div>
              )}

              {/* ── Polished Connected Ranking Sidebar ── */}
              {phase === 'playing' && (
                <div className="absolute left-4 sm:left-6 top-[110px] bottom-[110px] w-14 sm:w-16 flex flex-col justify-between z-20">
                  <div className="absolute left-1/2 top-4 bottom-4 w-[2px] bg-white/10 -translate-x-1/2 z-0 rounded-full" />
                  {slots.map((p, i) => (
                    <button key={i} onClick={() => place(i)} disabled={!!p || rolling}
                      className={`relative flex items-center gap-2 flex-1 max-h-[8.5%] px-1.5 rounded-[18px] transition-all duration-300 border-[1.5px] z-10 backdrop-blur-md
                        ${p ? 'bg-white/15 shadow-xl opacity-100' : 'bg-[#030305]/60 opacity-80 active:scale-95 border-white/15 hover:bg-white/10'}
                        ${flashSlot === i ? 'anim-pop' : ''}`}
                      style={p ? { borderColor: activeTheme.primary, boxShadow: `0 8px 30px ${activeTheme.primary}40` } : {}}>
                      <span className={`display-font text-[16px] font-black w-5 text-center shrink-0 drop-shadow-md ${p ? 'text-white' : 'text-white/40'}`}>{i + 1}</span>
                      <div className="flex-1 h-[80%] py-0.5">
                        {p ? (
                          <div className="w-full h-full rounded-[12px] overflow-hidden border border-white/20 bg-[#030305] relative shadow-inner">
                            {p.img && <img id={`slot-img-${i}`} src={p.img} className="w-full h-full object-cover" alt=""/>}
                          </div>
                        ) : <div className="w-full h-full flex items-center justify-center opacity-30"><div className="w-2 h-2 rounded-full bg-white shadow-[0_0_10px_white]" /></div>}
                      </div>
                    </button>
                  ))}
                </div>
              )}

              {/* ── World-Class Results Screen ── */}
              {phase === 'result' && (
                <div className="absolute inset-0 z-[60] glass-panel flex flex-col px-5 sm:px-10 pt-safe pb-safe overflow-y-auto no-scrollbar">
                  <div className="flex justify-between items-end mb-10 text-left shrink-0 mt-6">
                    <div className="min-w-0 pr-4">
                      <p className={`display-font font-black text-[11px] tracking-[0.3em] mb-2 uppercase drop-shadow-md`} style={{ color: activeTheme.primary }}>Session Complete</p>
                      <h2 className="display-font text-3xl sm:text-4xl font-black leading-none truncate text-white uppercase block drop-shadow-[0_0_30px_rgba(255,255,255,0.2)]">
                        {challengeTitle}
                      </h2>
                    </div>
                    <button onClick={() => { setNavStack(['domain']); setPhase('menu'); }} className="w-14 h-14 glass-premium border-white/20 rounded-full hover:bg-white/15 text-white active:scale-95 transition-all shadow-[0_10px_30px_rgba(0,0,0,0.5)] shrink-0 flex items-center justify-center">
                      <RefreshCw size={24} />
                    </button>
                  </div>
                  
                  <div className="space-y-4 mb-12 flex-1">
                    {slots.map((p, i) => (
                      <div key={i} className={`flex items-center gap-4 p-4 rounded-[24px] border-[1.5px] transition-all ${i === 0 ? 'shadow-[0_20px_50px_rgba(0,0,0,0.6)] scale-[1.03] border-none z-10 relative' : 'glass-premium border-white/15 hover:border-white/30'}`} style={i === 0 ? { background: `linear-gradient(135deg, ${activeTheme.primary}, ${activeTheme.secondary})`, color: (selection.domain === 'sports' ? '#fff' : '#030305') } : {}}>
                        <span className={`display-font w-8 font-black text-[28px] text-center shrink-0 ${i === 0 ? (selection.domain === 'sports' ? 'text-white/50' : 'text-[#030305]/40') : 'text-white/20'}`}>{i + 1}</span>
                        <div className={`w-14 h-14 rounded-[16px] overflow-hidden shrink-0 bg-[#030305] ${i === 0 ? 'border border-[#030305]/20 shadow-inner' : 'border border-white/15'}`}>
                          {p?.img && <img src={p.img} className="w-full h-full object-cover" alt=""/>}
                        </div>
                        <div className="flex-1 min-w-0 flex flex-col justify-center">
                          <p className="display-font font-black text-[15px] sm:text-[16px] uppercase tracking-widest text-left break-words line-clamp-2 leading-tight">{p?.name}</p>
                        </div>
                        {i === 0 && <StarIcon size={24} fill={selection.domain === 'sports' ? '#fff' : '#030305'} className={`ml-2 shrink-0 ${selection.domain === 'sports' ? 'text-white' : 'text-[#030305]'}`} />}
                      </div>
                    ))}
                  </div>

                  <div className="shrink-0 flex flex-col gap-4 mb-6">
                    {recordStatus === 'error' && (
                       <div className={`w-full py-5 rounded-[24px] bg-red-500/20 border border-red-500/50 text-white display-font font-black tracking-widest text-[12px] flex items-center justify-center gap-3 text-center px-4 shadow-[0_10px_30px_rgba(255,61,90,0.2)]`}>
                          <AlertCircle size={20} /> VIDEO PROCESSING FAILED
                       </div>
                    )}
                    
                    {recordStatus === 'recording' && (
                      <button onClick={stopRecordingAndCompile} className={`w-full py-5 rounded-[24px] bg-[#FF3D5A] border border-[#FF3D5A]/50 text-white display-font font-black tracking-widest text-[14px] flex items-center justify-center gap-3 active:scale-[0.98] shadow-[0_15px_40px_rgba(255,61,90,0.4)] transition-all`}>
                        <SquareIcon size={20} fill="white" /> STOP & COMPILE VIDEO
                      </button>
                    )}

                    {recordStatus === 'compiling' && (
                      <div className={`w-full py-5 rounded-[24px] glass-premium text-white display-font font-black tracking-widest text-[14px] flex items-center justify-center gap-4 transition-all opacity-90 border-white/20 shadow-xl`}>
                        <Loader2 className="animate-spin text-white" size={24} /> COMPILING VIDEO...
                      </div>
                    )}

                    {recordStatus === 'ready' && recordedVideoUrl && (
                      <a href={recordedVideoUrl.url} download={`BlindRank_Game_${Date.now()}.${recordedVideoUrl.ext}`} className={`w-full py-5 rounded-[24px] display-font font-black tracking-[0.15em] text-[14px] flex items-center justify-center gap-3 active:scale-[0.98] transition-all`} style={{ background: `linear-gradient(135deg, ${activeTheme.primary}, ${activeTheme.secondary})`, color: (selection.domain === 'sports' ? '#fff' : '#030305'), boxShadow: `0 15px 40px ${activeTheme.primary}50` }}>
                        <DownloadIcon size={22} /> SAVE VIDEO TO DEVICE
                      </a>
                    )}

                    <button onClick={() => {
                      const text = `🏆 My Blind Rank: ${challengeTitle}\n${slots.map((p, i) => `${i + 1}. ${p?.name}`).join('\n')}`;
                      if (navigator.share) navigator.share({ title: 'Blind Rank', text });
                    }} className={`w-full py-5 rounded-[24px] glass-premium text-white display-font font-black tracking-[0.15em] text-[14px] flex items-center justify-center gap-3 active:scale-[0.98] hover:bg-white/10 transition-all border-white/20 shadow-xl`}>
                      <Share2 size={20} /> SHARE RANKING LIST
                    </button>
                  </div>
                </div>
              )}

              {/* ── Bottom Ambient Info Pill ── */}
              <div className="absolute bottom-8 sm:bottom-12 inset-x-0 flex justify-center z-30 pointer-events-none pb-safe">
                <div className="glass-premium px-6 py-4 rounded-full flex items-center gap-4 shadow-[0_20px_50px_rgba(0,0,0,0.5)] border-white/20 bg-[#030305]/80">
                  <span className="display-font text-[11px] font-black uppercase tracking-[0.2em] text-white/50">BR-PRO</span>
                  <div className="w-[1.5px] h-4 bg-white/20" />
                  <div className="flex items-center gap-3 min-w-0">
                    <div className={`w-2.5 h-2.5 rounded-full animate-pulse shrink-0`} style={{ backgroundColor: activeTheme.primary, boxShadow: `0 0 15px ${activeTheme.primary}` }} />
                    <span className={`display-font text-[11px] font-black uppercase tracking-widest truncate max-w-[130px]`} style={{ color: activeTheme.primary }}>
                      {challengeTitle === 'BLIND RANK' ? 'SYSTEM READY' : challengeTitle}
                    </span>
                  </div>
                </div>
              </div>
            </div>
          );
        }

        const root = ReactDOM.createRoot(document.getElementById('root'));
        root.render(<App />);
    </script>
</body>
</html>


```
